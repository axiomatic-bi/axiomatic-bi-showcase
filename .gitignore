# ============================================================================
# Axiomatic BI Showcase - Git ignore baseline
# Static Astro site + technical portfolio artefacts
# ============================================================================

# --- Node / package managers ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Build output / caches (Astro + tooling) ---
dist/
.astro/
.cache/
.parcel-cache/
.turbo/
.vite/
coverage/

# --- Environment files / local overrides ---
.env
.env.*
!.env.example
!.env.template

# --- Secrets and credentials (defence in depth) ---
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
id_rsa
id_ed25519
credentials.json
secrets.json

# --- Python local environment (for pipeline/dev helpers) ---
.venv/
venv/
__pycache__/
*.py[cod]

# --- Logs and temporary files ---
*.log
*.tmp
*.temp
tmp/
temp/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo

# --- OS files ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Demo capture scratch space (MCP/video workflows) ---
media/capture/
media/raw/
media/exports/
recordings/
assets/original/

