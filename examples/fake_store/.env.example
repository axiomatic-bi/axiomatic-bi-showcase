# ==============================================================================
# Axiomatic Engine - Core Configuration
# ==============================================================================

# Target warehouse type. Options: 'duckdb', 'motherduck'
AXIOMATIC_WAREHOUSE_KIND=duckdb

# Warehouse location: local DuckDB file path or MotherDuck database URI (md:<database_name>)
AXIOMATIC_WAREHOUSE_PATH=./data/warehouse.duckdb

# Default schema used by ingestion loads
AXIOMATIC_WAREHOUSE_SCHEMA=bronze

# Local directory for DuckDB files and staging. Ensure this folder exists.
AXIOMATIC_STORAGE_PATH=./data/

# MotherDuck Token (Required only if AXIOMATIC_WAREHOUSE_KIND is 'motherduck')
# AXIOMATIC_MOTHERDUCK_ACCESS_TOKEN=your_token_here

# ==============================================================================
# Transformation Settings (dbt)
# ==============================================================================

# Enable transformation stage after ingestion
AXIOMATIC_TRANSFORM_ENABLED=false

# Transformation backend. Current supported value: 'dbt'
AXIOMATIC_TRANSFORM_BACKEND=dbt

# dbt project and profiles locations
AXIOMATIC_DBT_PROJECT_DIR=./dbt_project
AXIOMATIC_DBT_PROFILES_DIR=./dbt_project

# dbt profile and target names
AXIOMATIC_DBT_PROFILE_NAME=fake_store
AXIOMATIC_DBT_TARGET=dev

# Run dbt tests after dbt run
AXIOMATIC_DBT_RUN_TESTS=true

# Global engine safety settings
AXIOMATIC_API_TIMEOUT_SECONDS=30
AXIOMATIC_MAX_RETRIES=3

# ==============================================================================
# Project Specific - Fake Store API
# ==============================================================================

# Base URL for the Fake Store API
FAKE_STORE_API_URL=https://fakestoreapi.com

# API Key (If using a private/partner endpoint, otherwise leave blank)
FAKE_STORE_API_KEY=

# ==============================================================================
# Environment Settings
# ==============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO