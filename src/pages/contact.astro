---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import SectionHeading from "../components/layout/SectionHeading.astro";
import { withBase } from "../utils/urls";
import { BriefcaseBusiness, Download, FileText, Link2, Mail } from "lucide-react";
import cvPdf from "../../assets/cv-timothy-amison.pdf";
import heroContactImage from "../../assets/hero-contact.webp";

const contactEntry = await getEntry("contact", "main");

if (!contactEntry) {
  throw new Error("Missing contact content entry: main");
}

const { Content } = await contactEntry.render();
---

<BaseLayout title="Contact" description="Contact options for discovery calls and project conversations.">
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        breadcrumbs={[
          { label: "Home", href: withBase("/") },
          { label: "Contact" }
        ]}
        title={contactEntry.data.title}
        lede={contactEntry.data.summary}
      >
        <img
          slot="visual"
          class="hero-visual-image"
          src={heroContactImage.src}
          alt="Contact-themed visual showing connected communication channels."
          width={heroContactImage.width}
          height={heroContactImage.height}
          loading="eager"
          decoding="async"
        />
      </PageHeader>
    </div>
  </div>

  <div class="full-bleed tonal-band">
    <section class="band-inner contact-methods-section">
      <SectionHeading title="Contact methods">
        <BriefcaseBusiness slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <div class="contact-grid">
        <article class="contact-card">
          <h3>
            <Mail size={16} strokeWidth={2} />
            <span>Email</span>
          </h3>
          <p>
            <a href={`mailto:${contactEntry.data.email}`}>{contactEntry.data.email}</a>
          </p>
        </article>
        <article class="contact-card">
          <h3>
            <Link2 size={16} strokeWidth={2} />
            <span>LinkedIn</span>
          </h3>
          <p>
            <a class="button button-secondary" href={contactEntry.data.linkedinUrl} target="_blank" rel="noreferrer">
              Open LinkedIn profile
            </a>
          </p>
        </article>
        <article class="contact-card">
          <h3>
            <FileText size={16} strokeWidth={2} />
            <span>About Me and CV</span>
          </h3>
          <p class="contact-card-links">
            <a class="button button-secondary" href={withBase("/about")}>
              View About Me
            </a>
            <a class="button button-secondary" href={cvPdf} download>
              Download PDF <Download size={14} strokeWidth={2} />
            </a>
          </p>
        </article>
      </div>
      <p class="response-window">{contactEntry.data.responseWindow}</p>
    </section>
  </div>

  <section>
    <SectionHeading title="Enquiry guidance">
      <BriefcaseBusiness slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <div class="contact-content">
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .accent-band {
    background: var(--bleed-accent-bg);
  }

  .contact-methods-section {
    margin-bottom: 0;
  }

  .contact-grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
  }

  .contact-card {
    border-radius: var(--radius-md);
    background: var(--surface-on-bleed);
    box-shadow: var(--surface-on-bleed-shadow);
    padding: 0.85rem 0.95rem;
  }

  .contact-card h3 {
    margin: 0 0 0.45rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.95rem;
  }

  .contact-card p {
    margin: 0;
  }

  .contact-card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
  }

  .contact-card-links .button {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .response-window {
    margin-top: 0.8rem;
    color: var(--text-soft);
  }

  .contact-content :global(h2) {
    margin-top: 1.1rem;
    margin-bottom: 0.45rem;
    font-size: clamp(1.02rem, 1.7vw, 1.16rem);
  }

  .contact-content :global(p) {
    margin-bottom: 0.7rem;
  }
</style>
