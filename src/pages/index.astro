---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProofStrip from "../components/ProofStrip.astro";
import heroImage from "../../assets/hero-image.webp";
import { ArrowRight, Check, CircleAlert, Layers3 } from "lucide-react";

const primaryCta = {
  label: "Book a discovery call",
  href: "/contact"
};

const crossSourceMermaid = `flowchart LR
  sourceApis["Source APIs"] --> dataLoads["Automated loads"]
  fileStreams["File streams"] --> dataLoads
  dataLoads --> sharedModel["Shared model"]
  sharedModel --> biReports["Dashboards"]
  sharedModel --> aiContext["AI context"]`;

const proofChips = [
  { label: "Python orchestration" },
  { label: "dlt ingestion" },
  { label: "dbt transformation" },
  { label: "REST API sources" },
  { label: "DuckDB + MotherDuck" },
  { label: "Published ADRs" },
  { label: "Reproducible case study" },
  { label: "Client-owned code and data" }
];

---

<BaseLayout
  title="Reliable Reporting Systems and BI Delivery"
  description="Analytics engineering for client-owned reporting systems with reproducible pipelines, shared models, and clear handover."
  enableMermaid={true}
>
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        eyebrow="Home"
        title="Reliable reporting systems your team can own."
        lede="For operations, finance, and growth teams, this service replaces manual reporting work with an automated, governed data model your team can trust and run after handover."
      >
        <img
          slot="visual"
          class="hero-visual-image"
          src={heroImage.src}
          alt="Abstract glowing pipeline core with connected data flow lanes."
          width="1024"
          height="1024"
          loading="eager"
          decoding="async"
        />
      </PageHeader>
      <p class="hero-proofline">Client-owned delivery. Clear handover. Built for reporting and AI-assisted analysis.</p>
      <p class="hero-actions">
        <a class="button button-primary" href={primaryCta.href}>
          {primaryCta.label} <ArrowRight size={16} strokeWidth={2} />
        </a>
      </p>
    </div>
  </div>

  <div class="full-bleed proof-band">
    <div class="band-inner proof-band-inner">
      <ProofStrip
        title="Technology and delivery proof"
        intro="Engine orchestration combines dlt ingestion and dbt transformation with client-owned delivery assets. Planned next adapters include GraphQL API and SharePoint files."
        items={proofChips}
      />
    </div>
  </div>

  <section class="problem-section" aria-labelledby="problem-heading">
    <div class="problem-columns">
      <div class="problem-column-intro">
        <p class="section-label">Why reporting breaks</p>
        <h2 id="problem-heading">Why reporting fails long before the dashboard.</h2>
        <p class="section-intro">The delivery model below addresses the operational issues that make reporting hard to trust.</p>
        <p class="section-intro">This service provides consistent metrics, lower manual overhead, and auditable reporting paths.</p>
      </div>
      <div class="problem-column-stack" aria-label="Problems and solutions">
        <article class="proof-card problem-pair-card">
          <h3 class="problem-line">
            <CircleAlert size={14} strokeWidth={2.1} aria-hidden="true" />
            <span>Still relying on manual exports and ad hoc ingest?</span>
          </h3>
          <p class="solution-line">
            <Check size={14} strokeWidth={2.2} aria-hidden="true" />
            <span>Scheduled ingestion pipelines with explicit source contracts and repeatable runs.</span>
          </p>
        </article>
        <article class="proof-card problem-pair-card">
          <h3 class="problem-line">
            <CircleAlert size={14} strokeWidth={2.1} aria-hidden="true" />
            <span>Seeing different metric logic across reports?</span>
          </h3>
          <p class="solution-line">
            <Check size={14} strokeWidth={2.2} aria-hidden="true" />
            <span>Shared analytical models and governed definitions so every report uses the same logic.</span>
          </p>
        </article>
        <article class="proof-card problem-pair-card">
          <h3 class="problem-line">
            <CircleAlert size={14} strokeWidth={2.1} aria-hidden="true" />
            <span>Locked into a managed stack with unclear ownership?</span>
          </h3>
          <p class="solution-line">
            <Check size={14} strokeWidth={2.2} aria-hidden="true" />
            <span>Client-owned code, data, automation, and handover boundaries from the start.</span>
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="engine-overview" aria-labelledby="engine-overview-heading">
    <div class="engine-copy">
      <p class="section-label">Service architecture</p>
      <SectionHeading title="From source data to trusted reporting">
        <Layers3 slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <p id="engine-overview-heading">
        Data from APIs and file feeds is loaded on schedule, modelled into a shared reporting layer, and then used by
        dashboards and AI-assisted analysis.
      </p>
      <p>The focus is one trusted model, clear ownership, and straightforward handover.</p>
    </div>
    <div class="proof-card engine-diagram-card">
      <p class="engine-diagram-label">Delivery flow</p>
      <div class="mermaid">{crossSourceMermaid}</div>
    </div>
  </section>

  <div class="full-bleed example-band">
    <section class="proof-grid-section band-inner" aria-labelledby="proof-grid-heading">
      <p class="section-label">Example engagement</p>
      <h2 id="proof-grid-heading">Fake Store reference build: reproducible pipeline, modelled reporting, explicit reruns.</h2>
      <div class="proof-grid">
        <article class="proof-card">
          <h3>What changed</h3>
          <p>
            Built a Python orchestration layer around dlt ingestion and dbt-first transformation, with deterministic
            rerun policies across products, users, and carts.
          </p>
          <p>
            Evidence includes resource-level merge/replace configuration, reproducible run commands, and implementation
            artefacts in the published case study.
          </p>
          <p class="hero-actions">
            <a class="button button-primary" href="/case-studies/fake-store">
              Open Fake Store case study <ArrowRight size={16} strokeWidth={2} />
            </a>
            <a class="button button-secondary" href="/case-studies">
              View all case studies
            </a>
          </p>
          <p>A report screenshot slot can be added here once a publication-safe image is ready.</p>
        </article>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  :global(.hero-scene) {
    margin-bottom: 0;
  }

  .problem-section {
    padding-top: clamp(1.5rem, 3vw, 2.25rem);
  }

  .problem-columns {
    display: grid;
    gap: 1rem;
  }

  .problem-column-intro {
    display: grid;
    gap: 0.6rem;
    align-content: start;
  }

  .problem-column-stack {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .problem-pair-card h3 {
    margin-bottom: 0.45rem;
  }

  .problem-line {
    display: flex;
    gap: 0.45rem;
    align-items: flex-start;
  }

  .problem-line :global(svg) {
    margin-top: 0.2rem;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .problem-pair-card p {
    margin: 0;
  }

  .solution-line {
    display: flex;
    gap: 0.45rem;
    align-items: flex-start;
  }

  .solution-line :global(svg) {
    margin-top: 0.2rem;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .proof-band {
    background: color-mix(in srgb, var(--background, #050c1a) 90%, #13294d 10%);
  }

  .proof-band-inner {
    padding-top: clamp(1.5rem, 3vw, 2.25rem);
    padding-bottom: clamp(1.25rem, 2.2vw, 2rem);
  }

  .proof-band :global(.proof-strip) {
    padding-top: 0;
    margin-bottom: 0;
  }

  :global(.engine-overview) {
    display: grid;
    grid-template-columns: 1fr !important;
    gap: 1rem;
    align-items: start;
    padding-bottom: clamp(1rem, 2vw, 1.5rem);
  }

  .engine-copy {
    display: grid;
    gap: 0.75rem;
  }

  .engine-diagram-card {
    display: grid;
    gap: 0.6rem;
    overflow: hidden;
  }

  .engine-diagram-label {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .engine-diagram-card .mermaid {
    min-width: 0;
    width: 100%;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .engine-diagram-card .mermaid :global(svg) {
    width: 100% !important;
    max-width: 100%;
    height: auto !important;
  }

  .example-band {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    background: color-mix(in srgb, var(--background, #050c1a) 86%, #0f1c34 14%);
  }

  @media (min-width: 64rem) {
    .problem-columns {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.35fr);
      gap: 1.25rem;
    }
  }
</style>
