---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import { withBase } from "../utils/urls";
import heroImage from "../../assets/hero-image.webp";
import fakeStorePbiSalesImage from "../../assets/fake-store-pbi-sales.webp";
import { ArrowRight, Check, CircleAlert, Layers3 } from "lucide-react";

const primaryCta = {
  label: "Book a discovery call",
  href: "/contact"
};

const proofLinks = [
  { label: "Examples to get started", href: "/case-studies" },
  { label: "Fake store implementation", href: "/case-studies/fake-store" },
  { label: "Published ADRs", href: "https://github.com/axiomatic-bi/axiomatic-engine/tree/main/docs/adr" },
  { label: "Engine documentation", href: "https://github.com/axiomatic-bi/axiomatic-engine#readme" },
  { label: "Code you can see", href: "https://github.com/axiomatic-bi/axiomatic-engine" }
];

const deliveryScopeTags = [
  "Source integration",
  "Trusted metrics",
  "Reporting outputs",
  "Automated refresh",
  "Client ownership"
];

const deliveryItems = [
  {
    title: "Source integration",
    description: "Connect APIs, exports, and file-based data into repeatable ingestion workflows built for reporting use."
  },
  {
    title: "Warehouse modelling",
    description: "Turn raw source data into a shared reporting model with consistent definitions and reusable logic."
  },
  {
    title: "Reporting outputs",
    description: "Build dashboards and report layers from the same trusted model so teams can work from one set of numbers."
  },
  {
    title: "Automation and handover",
    description: "Add scheduled refreshes, documentation, and clear ownership boundaries so the system can be maintained after delivery."
  }
];

---

<BaseLayout
  title="Reliable Reporting Systems and BI Delivery"
  description="Analytics engineering for client-owned reporting systems with reproducible pipelines, shared models, and clear handover."
  enableMermaid={true}
>
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        breadcrumbs={[{ label: "Home" }]}
        title="Reliable business insights your team can own."
        lede="I help operations, finance, and growth teams replace manual reporting with automated pipelines, trusted metrics, and reporting your team can maintain after handover."
      >
        <img
          slot="visual"
          class="hero-visual-image"
          src={heroImage.src}
          alt="Abstract glowing pipeline core with connected data flow lanes."
          width="1024"
          height="1024"
          loading="eager"
          decoding="async"
        />
      </PageHeader>
      <p class="hero-actions">
        <a class="button button-primary" href={withBase(primaryCta.href)}>
          {primaryCta.label} <ArrowRight size={16} strokeWidth={2} />
        </a>
      </p>
    </div>
  </div>

  <div class="full-bleed">
    <section class="band-inner band-inner-short" aria-label="Delivery scope tags">
      <p class="proof-chip-list-intro">Client-owned delivery. Shared data models. Automated refreshes. Reporting and AI-ready outputs.</p>
      <ul class="proof-chip-list" role="list">
        {
          deliveryScopeTags.map((tag) => (
            <li class="proof-chip" role="listitem">{tag}</li>
          ))
        }
      </ul>
    </section>
  </div>

  <div class="full-bleed tonal-band">
    <section class="band-inner" aria-labelledby="problem-heading">
      <div class="problem-columns">
        <div class="problem-column-intro">
          <p class="section-label">Why reporting breaks</p>
          <h2 id="problem-heading">Why reporting fails long before the dashboard.</h2>
          <p class="section-intro">Most reporting problems start upstream: manual exports, inconsistent metric logic, and delivery models that leave teams dependent on outside tools or people.</p>
          <p class="section-intro">The star schema and semantic layer provides consistent metrics, lower manual overhead, and auditable reporting paths.</p>
        </div>
        <div class="problem-column-stack" aria-label="Problems and solutions">
          <article class="proof-card problem-pair-card">
            <h3 class="problem-line">
              <CircleAlert size={14} strokeWidth={2.1} aria-hidden="true" />
              <span>Manual exports and reporting.</span>
            </h3>
            <p class="solution-line">
              <Check size={14} strokeWidth={2.2} aria-hidden="true" />
              <span>Scheduled ingestion pipelines with explicit source contracts and repeatable runs.</span>
            </p>
          </article>
          <article class="proof-card problem-pair-card">
            <h3 class="problem-line">
              <CircleAlert size={14} strokeWidth={2.1} aria-hidden="true" />
              <span>Inconsistent metrics.</span>
            </h3>
            <p class="solution-line">
              <Check size={14} strokeWidth={2.2} aria-hidden="true" />
              <span>Shared analytical models and governed definitions so every report uses the same logic.</span>
            </p>
          </article>
          <article class="proof-card problem-pair-card">
            <h3 class="problem-line">
              <CircleAlert size={14} strokeWidth={2.1} aria-hidden="true" />
              <span>Poor ownership.</span>
            </h3>
            <p class="solution-line">
              <Check size={14} strokeWidth={2.2} aria-hidden="true" />
              <span>Client-owned code, data, automation, and handover boundaries from the start.</span>
            </p>
          </article>
        </div>
      </div>
    </section>
  </div>

  <div>
    <section class="band-inner" aria-labelledby="deliverables-heading">
      <p class="section-label">What I deliver</p>
      <h2 id="deliverables-heading">Reporting systems built for trust and handover.</h2>
      <p>I help teams connect source data, model it into a shared reporting layer, deliver reporting outputs, and automate the workflow behind them.r</p>
      <div class="deliverables-grid">
        {
          deliveryItems.map((item) => (
            <article class="proof-card deliverable-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </section>
  </div>

  <div class="full-bleed">
    <section class="band-inner" aria-labelledby="proof-grid-heading">
      <p class="section-label">Featured Example</p>
      <h2 id="proof-grid-heading">Reference build: retail reporting pipeline</h2>
      <div class="example-feature">
        <div class="example-copy">
          <h3>From API data to reporting-ready outputs</h3>
          <p> A working example showing how API data can be ingested, modelled into a shared reporting layer, and surfaced in reporting outputs.</p>
          <p> The full case study includes architecture, implementation detail, and reproducibility notes for technical review.</p>
          <p class="hero-actions">
            <a class="button button-primary" href={withBase("/case-studies/fake-store")}>
              Open Fake Store example <ArrowRight size={16} strokeWidth={2} />
            </a>
            <a class="button button-secondary" href={withBase("/case-studies")}>
              View all examples
            </a>
          </p>
        </div>
        <figure class="proof-image">
          <img
            src={fakeStorePbiSalesImage.src}
            alt="Fake Store sales dashboard page showing order and category level reporting."
            width={fakeStorePbiSalesImage.width}
            height={fakeStorePbiSalesImage.height}
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </section>
  </div>

  <div>
    <section class="band-inner" aria-labelledby="proof-links-heading">
      <p class="section-label">Technology and delivery proof</p>
      <h2 id="proof-links-heading">Evidence you can inspect</h2>
      <p>
        Engine orchestration combines dlt ingestion and dbt transformation with client-owned delivery assets.
        Planned next adapters include GraphQL API and SharePoint files.
      </p>
      <p class="proof-actions">
        {
          proofLinks.map((item) => (
            <a
              class="button button-secondary"
              href={item.href.startsWith("http") ? item.href : withBase(item.href)}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noreferrer" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </p>
    </section>
  </div>
 
</BaseLayout>

<style>
  .problem-columns {
    display: grid;
    gap: 1rem;
  }

  .problem-column-intro {
    display: grid;
    gap: 0.6rem;
    align-content: start;
  }

  .problem-column-stack {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .problem-pair-card h3 {
    margin-bottom: 0.45rem;
  }

  .problem-line {
    display: flex;
    gap: 0.45rem;
    align-items: flex-start;
  }

  .problem-line :global(svg) {
    margin-top: 0.2rem;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .problem-pair-card p {
    margin: 0;
  }

  .solution-line {
    display: flex;
    gap: 0.45rem;
    align-items: flex-start;
  }

  .solution-line :global(svg) {
    margin-top: 0.2rem;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .deliverables-grid {
    display: grid;
    gap: 1rem;
  }

  .deliverable-card {
    display: grid;
    gap: 0.6rem;
    align-content: start;
  }

  .deliverable-card h3 {
    margin: 0;
  }

  .deliverable-card p {
    margin: 0;
  }

  .proof-actions {
    margin: var(--space-4) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  :global(.engine-overview) {
    display: grid;
    grid-template-columns: 1fr !important;
    gap: 1rem;
    align-items: start;
  }

  .example-feature {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .example-copy {
    display: grid;
    gap: 0.8rem;
  }

  .example-copy h3 {
    margin: 0;
  }

  .proof-image {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--surface-border, #6ba6ff) 36%, transparent);
  }

  .proof-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .proof-chip-list-intro {
    text-align: center;
  }

  @media (min-width: 64rem) {
    .problem-columns {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.35fr);
      gap: 1.25rem;
    }

    .deliverables-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .example-feature {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    }
  }
</style>
