---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import EvidenceCallout from "../components/EvidenceCallout.astro";
import ClientPainPoints from "../components/ClientPainPoints";
import {
  ArrowRight,
  BriefcaseBusiness,
  CheckCircle2,
  Lightbulb,
  Microscope,
  Sparkles,
  Target
} from "lucide-react";
---

<BaseLayout
  title="Data Pipeline Delivery"
  description="Client-focused data pipeline delivery with automation, ownership, and trustworthy modelling outcomes."
  enableMermaid={true}
>
  <PageHeader
    eyebrow="Home"
    title="Build an AI-ready and analyst-ready data pipeline your team actually owns"
    lede="I deliver automated, source-agnostic pipelines with clear star schemas that keep SQL and DAX simpler, improve reporting trust, and support more consistent AI-assisted analysis."
  />

  <section>
    <h2 class="section-heading">
      <span class="section-heading-icon" aria-hidden="true"><BriefcaseBusiness size={18} strokeWidth={2} /></span>
      Start with a discovery call
    </h2>
    <p>
      If you are planning a new analytics stack or trying to stabilise an existing one, I can scope a
      commercial delivery plan with clear milestones, ownership boundaries, and measurable technical outcomes.
    </p>
    <p>
      <a class="button button-primary" href="/about#contact">
        Book a discovery call <ArrowRight size={16} strokeWidth={2} />
      </a>
    </p>
  </section>

  <section>
    <h2 class="section-heading">
      <span class="section-heading-icon" aria-hidden="true"><Target size={18} strokeWidth={2} /></span>
      What clients typically need solved
    </h2>
    <ClientPainPoints />
  </section>

  <section>
    <h2 class="section-heading">
      <span class="section-heading-icon" aria-hidden="true"><CheckCircle2 size={18} strokeWidth={2} /></span>
      Delivery outcomes
    </h2>
    <p>
      I implement end-to-end ingestion and transformation with explicit orchestration boundaries, then
      model clean star schemas so reporting tools can be used immediately without extra reshaping work.
    </p>
    <ul>
      <li>Star schemas designed for Power BI, Python, Tableau, R, or other downstream tooling.</li>
      <li>Warehouse and source agnostic implementation, with DuckDB and MotherDuck as standard recommendation.</li>
      <li>Documentation and handover that supports long-term client ownership.</li>
    </ul>
  </section>

  <section>
    <h2 class="section-heading">
      <span class="section-heading-icon" aria-hidden="true"><Lightbulb size={18} strokeWidth={2} /></span>
      Cross-source insights, not single-source dashboards
    </h2>
    <p>
      Pipeline design can combine multiple operational systems into one analytical model. A representative
      example is joining commerce and marketing data (for example Shopify plus Google Ads) to understand
      revenue, acquisition efficiency, and product performance in one trusted view.
    </p>
    <div class="mermaid">{`flowchart LR
  shopifySource["Shopify sales data"] --> unifiedModel["Unified reporting model"]
  googleAdsSource["Google Ads performance data"] --> unifiedModel
  productSource["Product and catalogue data"] --> unifiedModel
  unifiedModel --> biTools["BI tools and dashboards"]
  unifiedModel --> aiAssistant["AI-assisted analysis"]`}</div>
  </section>

  <section>
    <h2 class="section-heading">
      <span class="section-heading-icon" aria-hidden="true"><Microscope size={18} strokeWidth={2} /></span>
      Technical proof
    </h2>
    <p>
      Claims on this site are linked to implementation artefacts, architecture notes, and full
      architecture decision records.
    </p>
    <EvidenceCallout
      items={[
        {
          label: "Engine architecture and implementation scope",
          path: "context_docs/axiomatic_engine/architecture.md",
          type: "code",
          note: "Runtime boundaries and implemented capability."
        },
        {
          label: "Reference case study with reproducibility notes",
          path: "context_docs/project_fake_store/README.md",
          type: "code",
          note: "End-to-end medallion pipeline example."
        },
        {
          label: "Full architecture decision records",
          path: "src/content/adr/001-warehouse-adapter-hierarchy.md",
          type: "code",
          note: "All ADRs are browsable in the UI."
        }
      ]}
    />
    <p>
      <a class="button button-secondary" href="/engine">Engine Overview</a>{" "}
      <a class="button button-secondary" href="/case-studies/fake-store">Fake Store Case Study</a>
    </p>
  </section>

  <section>
    <h2 class="section-heading">
      <span class="section-heading-icon" aria-hidden="true"><Sparkles size={18} strokeWidth={2} /></span>
      Coming soon
    </h2>
    <p>
      MCP server support and an optional semantic API layer are planned to improve AI-assisted analysis
      consistency while retaining governed model logic.
    </p>
  </section>

  <section>
    <h2 class="section-heading">
      <span class="section-heading-icon" aria-hidden="true"><BriefcaseBusiness size={18} strokeWidth={2} /></span>
      Ready to scope your pipeline?
    </h2>
    <p>Book a discovery call to discuss sources, target warehouse, delivery timeline, and ownership model.</p>
    <p>
      <a class="button button-primary" href="/about#contact">
        Book a discovery call <ArrowRight size={16} strokeWidth={2} />
      </a>
    </p>
  </section>
</BaseLayout>
