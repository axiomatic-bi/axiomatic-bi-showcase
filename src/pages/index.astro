---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProofStrip from "../components/ProofStrip.astro";
import OutcomeHighlights from "../components/OutcomeHighlights.astro";
import CaseStudyPreviewGrid from "../components/CaseStudyPreviewGrid.astro";
import ReportingShowcase from "../components/ReportingShowcase.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import heroImage from "../../assets/hero-image.webp";
import { ArrowRight, Layers3, Network, SearchCheck } from "lucide-react";

const primaryCta = {
  label: "Book a discovery call",
  href: "/contact"
};

const caseStudies = await getCollection("caseStudies");

const crossSourceMermaid = `flowchart LR
  shopifySource["Shopify sales"] --> unifiedModel["Unified analytical model"]
  googleAdsSource["Google Ads"] --> unifiedModel
  productSource["Product catalogue"] --> unifiedModel
  unifiedModel --> biTools["BI dashboards"]
  unifiedModel --> aiAssistant["AI-assisted analysis"]`;

const proofChips = [
  { label: "Published ADR set" },
  { label: "1 reproducible case study" },
  { label: "Open engine architecture documentation" },
  { label: "Public implementation notes" },
  { label: "Client-owned delivery model" }
];

const proofCards = [
  {
    title: "Engine architecture",
    description: "Runtime boundaries, capabilities, and implementation scope.",
    href: "/engine",
    cta: "Open engine overview"
  },
  {
    title: "Reference case study",
    description: "End-to-end pipeline walkthrough with reproducibility notes.",
    href: "/case-studies/fake-store",
    cta: "Open fake store case study"
  },
  {
    title: "Architecture decisions",
    description: "Decision records behind engine and delivery approach.",
    href: "https://github.com/axiomatic-bi/axiomatic-engine/tree/main/docs/adr",
    cta: "View ADR repository"
  }
];

const outcomeCards = [
  { title: "Faster delivery", description: "Reusable patterns reduce setup time." },
  { title: "Clear handover", description: "Documentation makes the stack easier to run." },
  { title: "Cross-source visibility", description: "Multiple systems aligned in one reporting model." }
];

const caseStudyCards = caseStudies.map((entry) => ({
  href: `/case-studies/${entry.slug}`,
  title: entry.data.title,
  problem: "Reporting relied on fragmented source outputs and manual process checks.",
  change: "Built a reproducible pipeline and modelled layered analytical tables.",
  result: "Clear rerun behaviour and faster route from ingestion to decision-ready reporting."
}));

const processSteps = [
  { title: "Discovery", caption: "Scope sources, constraints, ownership, and reporting priorities before build." },
  { title: "Build", caption: "Implement ingestion, modelling, and reporting foundations with explicit boundaries." },
  { title: "Validate", caption: "Confirm quality, reproducibility, and confidence signals before handover." },
  { title: "Handover", caption: "Transfer documentation, run guidance, and operating ownership to your team." }
];

const heroHighlights = ["Reporting-ready models", "Client-owned handover", "Reusable delivery patterns", "AI-ready"];
---

<BaseLayout
  title="Premium Data and BI Delivery"
  description="Analytics engineering and reporting delivery with visible proof, clear ownership, and structured handover."
  enableMermaid={true}
>
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        eyebrow="Home"
        title="Reporting systems your team can trust and run."
        lede="I design and deliver reporting systems that reduce manual work, improve confidence in the numbers, and leave your team with something they can run confidently."
      >
        <img
          slot="visual"
          class="hero-visual-image"
          src={heroImage.src}
          alt="Abstract glowing pipeline core with connected data flow lanes."
          width="1024"
          height="1024"
          loading="eager"
          decoding="async"
        />
      </PageHeader>
      <p class="hero-proofline">Client-owned delivery. Clear handover. Built for reporting and AI-assisted analysis.</p>
      <ul class="hero-highlight-list" role="list" aria-label="Delivery highlights">
        {heroHighlights.map((item) => <li>{item}</li>)}
      </ul>
      <p class="hero-actions">
        <a class="button button-primary" href={primaryCta.href}>
          {primaryCta.label} <ArrowRight size={16} strokeWidth={2} />
        </a>
        <a class="button button-secondary" href="/case-studies">
          View case studies
        </a>
      </p>
    </div>
  </div>

  <ProofStrip
    title="Proof"
    intro="Review the architecture, delivery notes, and implementation decisions behind the work."
    items={proofChips}
  />

  <section class="problem-section" aria-labelledby="problem-heading">
    <p class="section-label">Where teams usually get stuck</p>
    <h2 id="problem-heading">Facing these problems?</h2>
    <p class="section-intro">Most clients arrive with one of these recurring constraints.</p>
    <div class="problem-grid">
      <article class="problem-card problem-card-featured">
        <span class="problem-icon" aria-hidden="true"><Network size={18} strokeWidth={2} /></span>
        <h3>Manual operations</h3>
        <p>Pipelines depend on brittle scripts or one person remembering each run.</p>
      </article>
      <article class="problem-card">
        <span class="problem-icon" aria-hidden="true"><SearchCheck size={18} strokeWidth={2} /></span>
        <h3>Low-trust reporting</h3>
        <p>Teams see different numbers because data quality and modelling standards drift.</p>
      </article>
      <article class="problem-card">
        <span class="problem-icon" aria-hidden="true"><Layers3 size={18} strokeWidth={2} /></span>
        <h3>Vendor lock-in</h3>
        <p>Ownership is unclear and analytical layers are not designed for reuse.</p>
      </article>
    </div>
  </section>

  <OutcomeHighlights
    featuredTitle="Trusted reporting foundation"
    featuredDescription="Clean models and stable pipelines that make reporting easier to trust and extend."
    items={outcomeCards}
  />

  <section class="engine-overview" aria-labelledby="engine-overview-heading">
    <div>
      <p class="section-label">How the work stays fast and structured</p>
      <SectionHeading title="A structured delivery model behind each engagement">
        <Layers3 slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <p id="engine-overview-heading">
        I use a repeatable delivery framework to speed up implementation, keep technical decisions
        explicit, and make handover easier. The result is tailored delivery without improvised architecture.
      </p>
    </div>
    <div class="mermaid">{crossSourceMermaid}</div>
  </section>

  <section class="proof-grid-section" aria-labelledby="proof-grid-heading">
    <p class="section-label">Evidence</p>
    <h2 id="proof-grid-heading">Implementation detail linked to artefacts</h2>
    <div class="proof-grid">
      {
        proofCards.map((item) => (
          <article class="proof-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a
              class="button button-secondary"
              href={item.href}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noreferrer" : undefined}
            >
              {item.cta}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <CaseStudyPreviewGrid items={caseStudyCards} />

  <ReportingShowcase />

  <ProcessSteps steps={processSteps} />

  <section class="roadmap-callout" aria-label="Roadmap">
    <p class="section-label">Roadmap</p>
    <h2>Planned next: semantic access and MCP support</h2>
    <p>Optional agent-facing layers are planned to support consistent analysis on governed models.</p>
  </section>

  <div class="full-bleed cta-band">
    <section class="final-cta" aria-label="Final call to action">
      <div class="final-cta-inner">
        <SectionHeading title="Ready to scope the right reporting foundation?">
          <ArrowRight slot="icon" size={18} strokeWidth={2} />
        </SectionHeading>
        <p>
          If you need a cleaner pipeline, more reliable reporting, or a stack your team can genuinely own,
          let&rsquo;s scope the right next step.
        </p>
        <p>
          <a class="button button-primary" href={primaryCta.href}>
            {primaryCta.label} <ArrowRight size={16} strokeWidth={2} />
          </a>
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
