---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { withBase } from "../utils/urls";
import heroImage from "../../assets/hero-image.webp";
import fakeStorePbiSalesImage from "../../assets/fake-store-pbi-sales.webp";
import { ArrowRight, Check, CircleAlert, Layers3 } from "lucide-react";

const primaryCta = {
  label: "Book a discovery call",
  href: "/contact"
};

const crossSourceMermaid = `flowchart LR
  sourceApis["<b>Source APIs</b><br/>Operational systems and service endpoints"] --> dataLoads["<b>Automated loads</b><br/>Scheduled ingestion with governed contracts"]
  fileStreams["<b>File streams</b><br/>Batch extracts and managed file drops"] --> dataLoads
  dataLoads --> sharedModel["<b>Shared model</b><br/>Reusable semantic layer for consistent metrics"]
  sharedModel --> biReports["<b>Dashboards</b><br/>Business reporting for operational decisions"]
  sharedModel --> aiContext["<b>AI context</b><br/>Structured inputs for assistant and agent workflows"]`;

const proofLinks = [
  { label: "Examples to get started", href: "/case-studies" },
  { label: "Fake store implementation", href: "/case-studies/fake-store" },
  { label: "Published ADRs", href: "https://github.com/axiomatic-bi/axiomatic-engine/tree/main/docs/adr" },
  { label: "Engine documentation", href: "https://github.com/axiomatic-bi/axiomatic-engine#readme" },
  { label: "Code you can see", href: "https://github.com/axiomatic-bi/axiomatic-engine" }
];

---

<BaseLayout
  title="Reliable Reporting Systems and BI Delivery"
  description="Analytics engineering for client-owned reporting systems with reproducible pipelines, shared models, and clear handover."
  enableMermaid={true}
>
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        breadcrumbs={[{ label: "Home" }]}
        title="Reliable reporting systems your team can own."
        lede="For operations, finance, and growth teams, this service replaces manual reporting work with an automated, governed data model your team can trust and run after handover."
      >
        <img
          slot="visual"
          class="hero-visual-image"
          src={heroImage.src}
          alt="Abstract glowing pipeline core with connected data flow lanes."
          width="1024"
          height="1024"
          loading="eager"
          decoding="async"
        />
      </PageHeader>
      <p class="hero-proofline">Client-owned delivery. Clear handover. Built for reporting and AI-assisted analysis.</p>
      <p class="hero-actions">
        <a class="button button-primary" href={withBase(primaryCta.href)}>
          {primaryCta.label} <ArrowRight size={16} strokeWidth={2} />
        </a>
      </p>
    </div>
  </div>

  <section class="proof-strip proof-links-strip" aria-labelledby="proof-links-heading">
    <p class="section-label">Technology and delivery proof</p>
    <h2 id="proof-links-heading">Evidence you can inspect</h2>
    <p>
      Engine orchestration combines dlt ingestion and dbt transformation with client-owned delivery assets.
      Planned next adapters include GraphQL API and SharePoint files.
    </p>
    <p class="proof-actions">
      {
        proofLinks.map((item) => (
          <a
            class="button button-secondary"
            href={item.href.startsWith("http") ? item.href : withBase(item.href)}
            target={item.href.startsWith("http") ? "_blank" : undefined}
            rel={item.href.startsWith("http") ? "noreferrer" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </p>
  </section>

  <div class="full-bleed problem-band">
    <section class="band-inner problem-band-section" aria-labelledby="problem-heading">
      <div class="problem-columns">
        <div class="problem-column-intro">
          <p class="section-label">Why reporting breaks</p>
          <h2 id="problem-heading">Why reporting fails long before the dashboard.</h2>
          <p class="section-intro">The delivery model below addresses the operational issues that make reporting hard to trust.</p>
          <p class="section-intro">This service provides consistent metrics, lower manual overhead, and auditable reporting paths.</p>
        </div>
        <div class="problem-column-stack" aria-label="Problems and solutions">
          <article class="proof-card problem-pair-card">
            <h3 class="problem-line">
              <CircleAlert size={14} strokeWidth={2.1} aria-hidden="true" />
              <span>Still relying on manual exports and ad hoc ingest?</span>
            </h3>
            <p class="solution-line">
              <Check size={14} strokeWidth={2.2} aria-hidden="true" />
              <span>Scheduled ingestion pipelines with explicit source contracts and repeatable runs.</span>
            </p>
          </article>
          <article class="proof-card problem-pair-card">
            <h3 class="problem-line">
              <CircleAlert size={14} strokeWidth={2.1} aria-hidden="true" />
              <span>Seeing different metric logic across reports?</span>
            </h3>
            <p class="solution-line">
              <Check size={14} strokeWidth={2.2} aria-hidden="true" />
              <span>Shared analytical models and governed definitions so every report uses the same logic.</span>
            </p>
          </article>
          <article class="proof-card problem-pair-card">
            <h3 class="problem-line">
              <CircleAlert size={14} strokeWidth={2.1} aria-hidden="true" />
              <span>Locked into a managed stack with unclear ownership?</span>
            </h3>
            <p class="solution-line">
              <Check size={14} strokeWidth={2.2} aria-hidden="true" />
              <span>Client-owned code, data, automation, and handover boundaries from the start.</span>
            </p>
          </article>
        </div>
      </div>
    </section>
  </div>

  <section class="engine-overview section-before-band" aria-labelledby="engine-overview-heading">
    <div class="engine-copy">
      <p class="section-label">Service architecture</p>
      <SectionHeading title="From source data to trusted reporting">
        <Layers3 slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <p id="engine-overview-heading">
        Data from APIs and file feeds is loaded on schedule, modelled into a shared reporting layer, and then used by
        dashboards and AI-assisted analysis.
      </p>
      <p>The focus is one trusted model, clear ownership, and straightforward handover.</p>
    </div>
    <div class="engine-diagram-card">
      <p class="engine-diagram-label">Delivery flow</p>
      <div class="mermaid">{crossSourceMermaid}</div>
    </div>
  </section>

  <div class="full-bleed">
    <section class="proof-grid-section band-inner" aria-labelledby="proof-grid-heading">
      <p class="section-label">Example engagement</p>
      <h2 id="proof-grid-heading">Fake Store reference build</h2>
      <p class="section-intro">Reproducible pipeline, modelled reporting, explicit reruns.</p>
      <div class="example-feature">
        <div class="example-copy">
          <h3>From API data to reporting-ready outputs</h3>
          <p>
            This reference project shows the delivery pattern used in client engagements: scheduled ingestion, dbt-led
            transformation, and a shared model for reporting.
          </p>
          <p>
            The case study documents architecture, reproducibility commands, and implementation evidence so you can
            inspect how the warehouse outputs map into Power BI.
          </p>
          <p class="hero-actions">
            <a class="button button-primary" href={withBase("/case-studies/fake-store")}>
              Open Fake Store example <ArrowRight size={16} strokeWidth={2} />
            </a>
            <a class="button button-secondary" href={withBase("/case-studies")}>
              View all examples
            </a>
          </p>
        </div>
        <figure class="proof-image">
          <img
            src={fakeStorePbiSalesImage.src}
            alt="Fake Store sales dashboard page showing order and category level reporting."
            width={fakeStorePbiSalesImage.width}
            height={fakeStorePbiSalesImage.height}
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .problem-columns {
    display: grid;
    gap: 1rem;
  }

  .problem-column-intro {
    display: grid;
    gap: 0.6rem;
    align-content: start;
  }

  .problem-column-stack {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .problem-pair-card h3 {
    margin-bottom: 0.45rem;
  }

  .problem-line {
    display: flex;
    gap: 0.45rem;
    align-items: flex-start;
  }

  .problem-line :global(svg) {
    margin-top: 0.2rem;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .problem-pair-card p {
    margin: 0;
  }

  .solution-line {
    display: flex;
    gap: 0.45rem;
    align-items: flex-start;
  }

  .solution-line :global(svg) {
    margin-top: 0.2rem;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .proof-links-strip {
    margin-bottom: 0;
  }

  .problem-band {
    background: var(--bleed-band-blue);
  }

  .problem-band-section {
    margin-bottom: 0;
    padding-top: clamp(2.75rem, 4.5vw, 4rem);
    padding-bottom: clamp(2.75rem, 4.5vw, 4rem);
  }

  .proof-actions {
    margin: var(--space-4) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  :global(.engine-overview) {
    display: grid;
    grid-template-columns: 1fr !important;
    gap: 1rem;
    align-items: start;
  }

  .engine-copy {
    display: grid;
    gap: 0.75rem;
  }

  .engine-diagram-card {
    display: grid;
    gap: 0.6rem;
    overflow: visible;
  }

  .engine-diagram-label {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .full-bleed .proof-grid-section {
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  .example-feature {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .example-copy {
    display: grid;
    gap: 0.8rem;
  }

  .example-copy h3 {
    margin: 0;
  }

  .proof-image {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--surface-border, #6ba6ff) 36%, transparent);
  }

  .proof-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (min-width: 64rem) {
    .problem-columns {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.35fr);
      gap: 1.25rem;
    }

    .example-feature {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    }
  }
</style>
