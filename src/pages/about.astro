---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { CheckCircle2, Microscope, Target, UserRound } from "lucide-react";
---

<BaseLayout title="About" description="Background and technical approach for this portfolio.">
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        eyebrow="About"
        title="About"
        lede="Background, principles, and scope boundaries behind the Axiomatic BI Showcase."
      />
    </div>
  </div>

  <section>
    <SectionHeading title="Background">
      <UserRound slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>
      This showcase documents practical data engineering work centred on pipeline orchestration,
      modelling discipline, and transparent technical decision-making.
    </p>
  </section>

  <section>
    <SectionHeading title="Technical Principles">
      <Microscope slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>
      Claims are evidence-backed, workflows are reproducible where possible, and limitations are stated
      directly. Content prioritises clarity and maintainability over marketing language.
    </p>
  </section>

  <section>
    <SectionHeading title="How I Evaluate Trade-offs">
      <Target slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>
      Trade-offs are assessed across reliability, maintainability, operational risk, and implementation
      complexity. Decisions are considered stronger when they are testable and explainable in code.
    </p>
  </section>

  <section>
    <SectionHeading title="What This Showcase Is and Is Not">
      <CheckCircle2 slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>
      This is a technical portfolio, not a production platform. It emphasises demonstrable patterns and
      lessons, and marks planned capability areas clearly rather than overstating maturity.
    </p>
  </section>

</BaseLayout>
