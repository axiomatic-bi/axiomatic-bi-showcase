---
import { getEntry } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import EvidenceCallout from "../components/EvidenceCallout.astro";
import ReproSteps from "../components/ReproSteps.astro";
import DecisionLog from "../components/DecisionLog.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { fakeStoreLinks } from "../utils/externalLinks";
import { withBase } from "../utils/urls";
import { CheckCircle2, ExternalLink, FileCode2, Lightbulb, Microscope, Target } from "lucide-react";

const engineEntry = await getEntry("engine", "overview");
if (!engineEntry) {
  throw new Error("Engine overview entry not found.");
}
const { Content } = await engineEntry.render();
const engineArchitectureMermaid = `flowchart LR
  sourceNode["<b>Source protocols</b><br/>Typed source contracts expose extraction resources"] --> ingestNode["<b>Ingestion stage</b><br/>dlt orchestration handles extraction and load execution"]
  ingestNode --> warehouseNode["<b>Warehouse adapter</b><br/>Backend-specific load behaviour remains isolated"]
  warehouseNode --> transformNode["<b>Transformation adapter</b><br/>dbt execution applies model contracts and quality checks"]`;

const engineScopeMermaid = `flowchart LR
  subgraph sourceGroup["Sources currently supported"]
    direction TB
    restNode["REST API source"]
    fileNode["File source"]
  end

  subgraph storageGroup["Storage currently supported"]
    direction TB
    dltNode["dlt-managed landing/load"]
  end

  subgraph warehouseGroup["Warehouses currently supported"]
    direction TB
    duckdbNode["DuckDB"]
    motherduckNode["MotherDuck"]
  end

  subgraph plannedGroup["Planned extensions"]
    direction TB
    s3Node["S3 storage"]
    gcsNode["GCS storage"]
    bigqueryNode["BigQuery warehouse"]
  end

  restNode --> dltNode
  fileNode --> dltNode
  dltNode --> duckdbNode
  dltNode --> motherduckNode
  dltNode -. planned .-> s3Node
  dltNode -. planned .-> gcsNode
  dltNode -. planned .-> bigqueryNode`;
---

<BaseLayout
  title="Engine Overview"
  description="Architecture and decisions behind the Axiomatic Engine."
  enableMermaid={true}
>
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        breadcrumbs={[
          { label: "Home", href: withBase("/") },
          { label: "Engine" }
        ]}
        title="Engine Overview"
        lede="Contract-first orchestration design for ingestion, transformation, and warehouse execution."
      />
      <div class="engine-actions">
        <a class="button button-primary" href={fakeStoreLinks.exampleCode} target="_blank" rel="noreferrer">
          View example project <ExternalLink size={16} strokeWidth={2} />
        </a>
        <a
          class="button button-secondary"
          href="https://github.com/axiomatic-bi/axiomatic-engine/tree/main/docs/adr"
          target="_blank"
          rel="noreferrer"
        >
          View ADRs <ExternalLink size={16} strokeWidth={2} />
        </a>
      </div>
    </div>
  </div>

  <section class="engine-repro-section">
    <p class="section-label">Quick overview</p>
    <SectionHeading title="At a glance" />
    <div class="glance-grid" role="list" aria-label="Engine overview highlights">
      {engineEntry.data.highlights.map((item) => (
        <article class="glance-card" role="listitem">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <p class="section-label">Context</p>
    <SectionHeading title="Problem">
      <Target slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>{engineEntry.data.problemStatement}</p>
  </section>

  <div class="full-bleed accent-band">
    <section class="band-inner band-inner-wide accent-section">
      <p class="section-label">Delivery architecture</p>
      <SectionHeading title="Architecture">
        <Microscope slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <div class="architecture-flow-layout">
        <div class="architecture-flow-left">
          {engineEntry.data.architectureIntro.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
        <div class="architecture-flow-right">
          <div class="mermaid">{engineArchitectureMermaid}</div>
        </div>
      </div>
    </section>
  </div>

  <section>
    <p class="section-label">Design decisions</p>
    <SectionHeading title="Execution and backend strategy">
      <Microscope slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    {engineEntry.data.strategySections.map((section) => (
      <>
        <h3>{section.heading}</h3>
        <p>{section.body}</p>
      </>
    ))}
  </section>

  <div class="full-bleed">
    <section class="band-inner band-inner-wide engine-scope-section">
      <p class="section-label">Delivery scope</p>
      <SectionHeading title="Implemented scope and declared extensions">
        <CheckCircle2 slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <p>{engineEntry.data.scopeSummary}</p>
      <div class="mermaid">{engineScopeMermaid}</div>
    </section>
  </div>

  <section>
    <p class="section-label">Delivery notes</p>
    <SectionHeading title="Trade-offs and Lessons">
      <Lightbulb slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>{engineEntry.data.tradeOffs}</p>
  </section>

  <section>
    <p class="section-label">Reproducibility</p>
    <SectionHeading title="Reproducibility Notes">
      <Target slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <ReproSteps
      steps={[
        "cd examples/fake_store",
        "uv sync",
        "uv run python run_pipeline.py --skip-transforms",
        "uv run python run_pipeline.py --run-transforms",
        "# pip alternative: python -m pip install -r requirements.txt"
      ]}
      assumptions={[
        "Python 3.10+ is available and dependencies are installed from examples/fake_store.",
        "Copy .env.example to .env and set AXIOMATIC_* values for your chosen warehouse.",
        "Network access is available for Fake Store API calls."
      ]}
      limitations={[
        "Engine-level execution is demonstrated through the Fake Store project runner rather than a standalone engine CLI.",
        "Transformation coverage depends on local dbt profile/target settings."
      ]}
    />
    <p>
      <a class="button button-secondary" href={fakeStoreLinks.exampleCode} target="_blank" rel="noreferrer">
        Open Fake Store example project
      </a>
    </p>
  </section>

  <section>
    <p class="section-label">Evidence</p>
    <SectionHeading title="Evidence and Decision Log">
      <Microscope slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <EvidenceCallout
      items={engineEntry.data.evidence.map((item) => ({ label: item.claim, path: item.sourcePath, type: item.type }))}
    />
    <DecisionLog decisions={engineEntry.data.decisions} />
    <p>
      <a
        class="button button-secondary"
        href="https://github.com/axiomatic-bi/axiomatic-engine/tree/main/docs/adr"
        target="_blank"
        rel="noreferrer"
      >
        See all ADRs
      </a>
    </p>
  </section>

  <section>
    <p class="section-label">Narrative detail</p>
    <SectionHeading title="Source Narrative">
      <FileCode2 slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <div class="source-narrative-content">
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .engine-actions {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0 0 1rem;
  }

  .glance-grid {
    display: grid;
    gap: 0.8rem;
    margin-top: 0.55rem;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
  }

  .glance-card {
    background: color-mix(in srgb, var(--surface, #111723) 86%, transparent);
    border-radius: var(--radius-md);
    padding: 0.8rem 0.85rem;
  }

  .glance-card h3 {
    margin: 0 0 0.35rem;
    font-size: 0.98rem;
  }

  .glance-card p {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .accent-band {
    background: var(--bleed-accent-bg);
  }

  .accent-section {
    margin-bottom: 0;
    padding-top: clamp(2.75rem, 4.5vw, 4rem);
    padding-bottom: clamp(2.75rem, 4.5vw, 4rem);
  }

  .engine-scope-section {
    margin-bottom: 0;
    padding-top: clamp(2.1rem, 3.8vw, 3rem);
    padding-bottom: clamp(2.1rem, 3.8vw, 3rem);
  }

  .architecture-flow-layout {
    display: grid;
    gap: 1rem;
    align-items: start;
    margin-top: 0.6rem;
  }

  .architecture-flow-left,
  .architecture-flow-right {
    display: grid;
    gap: 0.75rem;
    align-content: start;
  }

  .architecture-flow-left p {
    margin: 0;
  }

  .source-narrative-content :global(h2) {
    font-size: clamp(1.02rem, 1.7vw, 1.16rem);
    margin-top: 1rem;
  }

  .source-narrative-content :global(h3) {
    font-size: clamp(0.94rem, 1.5vw, 1.05rem);
  }

  .engine-repro-section :global(pre) {
    border: 0;
  }

  .mermaid :global(.cluster rect) {
    stroke: none !important;
    stroke-width: 0 !important;
  }

  @media (max-width: 680px) {
    .engine-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }

  @media (min-width: 64rem) {
    .architecture-flow-layout {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }
  }
</style>
