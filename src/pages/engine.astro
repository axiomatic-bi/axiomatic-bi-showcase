---
import { getEntry } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import EvidenceCallout from "../components/content/EvidenceCallout.astro";
import ReproSteps from "../components/content/ReproSteps.astro";
import DecisionLog from "../components/content/DecisionLog.astro";
import SectionHeading from "../components/layout/SectionHeading.astro";
import { fakeStoreLinks } from "../utils/externalLinks";
import { withBase } from "../utils/urls";
import { CheckCircle2, ExternalLink, FileCode2, Lightbulb, Microscope, Target } from "lucide-react";
import heroEngineImage from "../../assets/hero-engine.webp";

const engineEntry = await getEntry("engine", "overview");
if (!engineEntry) {
  throw new Error("Engine overview entry not found.");
}
const { Content } = await engineEntry.render();
const engineArchitectureMermaid = `%%{init: {'flowchart': {'htmlLabels': true}} }%%
flowchart LR
  sourceNode["<div style='width:17rem; text-align:center;'><b>Source protocols</b><div style='margin-top:0.5rem;'>Typed source contracts expose extraction resources</div></div>"] --> ingestNode["<div style='width:17rem; text-align:center;'><b>Ingestion stage</b><div style='margin-top:0.5rem;'>dlt orchestration handles extraction and load execution</div></div>"]
  ingestNode --> warehouseNode["<div style='width:17rem; text-align:center;'><b>Warehouse adapter</b><div style='margin-top:0.5rem;'>Backend-specific load behaviour remains isolated</div></div>"]
  warehouseNode --> transformNode["<div style='width:17rem; text-align:center;'><b>Transformation adapter</b><div style='margin-top:0.5rem;'>dbt execution applies model contracts and quality checks</div></div>"]
  transformNode -. planned .-> semanticNode["<div style='width:17rem; text-align:center;'><b>Semantic translator (planned)</b><div style='margin-top:0.5rem;'>Converts dbt semantic definitions for MCP consumption</div></div>"]`;

const crossSourceMermaid = `flowchart LR
  sourceApis["<b>Source APIs</b><br/>Operational systems and service endpoints"] --> dataLoads["<b>Automated loads</b><br/>Scheduled ingestion with governed contracts"]
  fileStreams["<b>File streams</b><br/>Batch extracts and managed file drops"] --> dataLoads
  dataLoads --> sharedModel["<b>Shared model</b><br/>Reusable semantic layer for consistent metrics"]
  sharedModel --> biReports["<b>Dashboards</b><br/>Business reporting for operational decisions"]
  sharedModel --> aiContext["<b>AI context</b><br/>Structured inputs for assistant and agent workflows"]`;

---


<BaseLayout
  title="Engine Overview"
  description="Architecture and decisions behind the Axiomatic Engine."
  enableMermaid={true}
>
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        breadcrumbs={[
          { label: "Home", href: withBase("/") },
          { label: "Engine" }
        ]}
        title="Engine Overview"
        lede="Contract-first orchestration design for ingestion, transformation, and warehouse execution."
      >
        <img
          slot="visual"
          class="hero-visual-image"
          src={heroEngineImage.src}
          alt="Abstract engine architecture visual with layered blue and purple data paths."
          width={heroEngineImage.width}
          height={heroEngineImage.height}
          loading="eager"
          decoding="async"
        />
      </PageHeader>
      <div class="engine-actions">
        <a class="button button-primary" href={fakeStoreLinks.exampleCode} target="_blank" rel="noreferrer">
          View example project <ExternalLink size={16} strokeWidth={2} />
        </a>
        <a
          class="button button-secondary"
          href="https://github.com/axiomatic-bi/axiomatic-engine/tree/main/docs/adr"
          target="_blank"
          rel="noreferrer"
        >
          View ADRs <ExternalLink size={16} strokeWidth={2} />
        </a>
      </div>
    </div>
  </div>

  <div class="full-bleed tonal-band">
    <section class="band-inner ">
      <p class="section-label">Quick overview</p>
      <SectionHeading title="At a glance" />
      <div class="glance-grid" role="list" aria-label="Engine overview highlights">
        {engineEntry.data.highlights.map((item) => (
          <article class="glance-card" role="listitem">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>
  </div>

  <div>
    <section class="band-inner">
      <p class="section-label">Context</p>
      <SectionHeading title="Problem">
        <Target slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <p>{engineEntry.data.problemStatement}</p>
    </section>
  </div>

  <div class="full-bleed accent-band">
    <section class="band-inner accent-section">
      <p class="section-label">Delivery architecture</p>
      <SectionHeading title="Architecture">
        <Microscope slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <div class="architecture-flow-layout">
        <div class="architecture-flow-left">
          {engineEntry.data.architectureIntro.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
        <div class="architecture-flow-right">
          <div class="mermaid">{engineArchitectureMermaid}</div>
        </div>
      </div>
    </section>
  </div>

  <div>
    <section class="band-inner">
      <p class="section-label">Design decisions</p>
      <SectionHeading title="Execution and backend strategy">
        <Microscope slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      {engineEntry.data.strategySections.map((section) => (
        <>
          <h3>{section.heading}</h3>
          <p>{section.body}</p>
        </>
      ))}
    </section>
  </div>
  <div class="full-bleed tonal-band">
    <section class="band-inner" aria-labelledby="engine-overview-heading">
      <div class="engine-copy">
        <p class="section-label">What I deliver</p>
        <SectionHeading title="From source data to trusted reporting" />
        <p id="engine-overview-heading">
          Data from APIs and files is loaded on a schedule, modelled into a shared reporting layer, and used across dashboards and AI-assisted workflows. 
        </p>
        <p>The goal is one trusted model, clear ownership, and straightforward handover.</p>
      </div>
      <div class="engine-diagram-card">
        <div class="mermaid">{crossSourceMermaid}</div>
      </div>
    </section>
  </div>
  
  <div>
    <section class="band-inner engine-scope-section">
      <p class="section-label">Delivery scope</p>
      <SectionHeading title="Implemented scope and declared extensions">
        <CheckCircle2 slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <p>{engineEntry.data.scopeSummary}</p>
      <p>
        <strong>Implemented:</strong> REST and file ingestion, Duck-compatible warehouses, and dbt-first transformation.
      </p>
      <p>
        <strong>Phase 1 roadmap:</strong> S3, GCS, S3-compatible storage, and BigQuery.
      </p>
      <p>
        <strong>Phase 2 roadmap:</strong> GraphQL API, SQL source, vendor REST connectors, PostgreSQL, Snowflake, and
        Redshift.
      </p>
      <p> 
        <strong>Phase 3 roadmap:</strong> SharePoint, OneDrive, Fabric, Databricks, and Azure Blob/ADLS.
      </p>
    </section>
  </div>

  <div>
    <section>
      <p class="section-label">Delivery notes</p>
      <SectionHeading title="Trade-offs and Lessons">
        <Lightbulb slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <p>{engineEntry.data.tradeOffs}</p>
    </section>
  </div>

  <div>
    <section>
      <p class="section-label">Reproducibility</p>
      <SectionHeading title="Reproducibility Notes">
        <Target slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <ReproSteps
        steps={[
          "cd examples/fake_store",
          "uv sync",
          "uv run python run_pipeline.py --skip-transforms",
          "uv run python run_pipeline.py --run-transforms",
          "# pip alternative: python -m pip install -r requirements.txt"
        ]}
        assumptions={[
          "Python 3.10+ is available and dependencies are installed from examples/fake_store.",
          "Copy .env.example to .env and set AXIOMATIC_* values for your chosen warehouse.",
          "Network access is available for Fake Store API calls."
        ]}
        limitations={[
          "Engine-level execution is demonstrated through the Fake Store project runner rather than a standalone engine CLI.",
          "Transformation coverage depends on local dbt profile/target settings."
        ]}
      />
      <p>
        <a class="button button-secondary" href={fakeStoreLinks.exampleCode} target="_blank" rel="noreferrer">
          Open Fake Store example project
        </a>
      </p>
    </section>
  </div>

  <div>
    <section>
      <p class="section-label">Evidence</p>
      <SectionHeading title="Evidence and Decision Log">
        <Microscope slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <EvidenceCallout
        items={engineEntry.data.evidence.map((item) => ({ label: item.claim, path: item.sourcePath, type: item.type }))}
      />
      <DecisionLog decisions={engineEntry.data.decisions} />
      <p>
        <a
          class="button button-secondary"
          href="https://github.com/axiomatic-bi/axiomatic-engine/tree/main/docs/adr"
          target="_blank"
          rel="noreferrer"
        >
          See all ADRs
        </a>
      </p>
    </section>
  </div>

  <div>
    <section>
      <p class="section-label">Narrative detail</p>
      <SectionHeading title="Source Narrative">
        <FileCode2 slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <div class="source-narrative-content">
        <Content />
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .engine-actions {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0 0 1rem;
  }

  .glance-grid {
    display: grid;
    gap: 0.8rem;
    margin-top: 0.55rem;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
  }

  .glance-card {
    background: var(--surface-on-bleed);
    box-shadow: var(--surface-on-bleed-shadow);
    border-radius: var(--radius-md);
    padding: var(--kpi-card-padding);
  }

  .glance-card h3 {
    margin: 0 0 0.35rem;
    font-size: 0.98rem;
  }

  .glance-card p {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .architecture-flow-layout {
    display: grid;
    gap: 1rem;
    align-items: start;
    margin-top: 0.6rem;
  }

  .architecture-flow-left,
  .architecture-flow-right {
    display: grid;
    gap: 0.75rem;
    align-content: start;
    min-width: 0;
  }

  .architecture-flow-left p {
    margin: 0;
  }

  .source-narrative-content :global(h2) {
    font-size: clamp(1.02rem, 1.7vw, 1.16rem);
    margin-top: 1rem;
  }

  .source-narrative-content :global(h3) {
    font-size: clamp(0.94rem, 1.5vw, 1.05rem);
  }

  @media (max-width: 680px) {
    .engine-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .engine-actions .button {
      width: auto;
      max-width: 100%;
    }
  }

  @media (min-width: 64rem) {
    .architecture-flow-layout {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }
  }
</style>
