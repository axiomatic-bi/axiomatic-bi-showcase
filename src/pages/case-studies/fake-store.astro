---
import { getEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ReproSteps from "../../components/ReproSteps.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { withBase } from "../../utils/urls";
import { fakeStoreLinks } from "../../utils/externalLinks";
import fakeStoreSalesPageImage from "../../../assets/fake-store-sales-page.webp";
import fakeStorePbiModelImage from "../../../assets/fake-store-pbi-model.webp";
import { ExternalLink } from "lucide-react";

const fakeStoreEntry = await getEntry("caseStudies", "fake-store");
const fakeStoreTransformationMermaid = `flowchart TB
  subgraph ingestGroup["Ingestion"]
    direction LR
    apiNode["<b>API extraction</b><br/>Products, users, carts via dlt resources"]
    bronzeNode["<b>Bronze load</b><br/>Raw outputs persisted to warehouse tables"]
    ingestOut[" "]
    apiNode --> bronzeNode --> ingestOut
  end
  subgraph transformGroup["Transformation"]
    direction LR
    transformIn[" "]
    silverNode["<b>Silver staging</b><br/>Typed and normalised dbt models"]
    goldNode["<b>Gold star schema</b><br/>Conformed dimensions and fact tables for analytics"]
    martsNode["<b>Mart layer (optional)</b><br/>Derived serving views for consumers"]
    transformOut[" "]
    transformIn --> silverNode --> goldNode
    goldNode -.-> martsNode
    goldNode --> transformOut
    martsNode -.-> transformOut
  end
  subgraph consumeGroup["Consumption"]
    direction LR
    consumeIn[" "]
    consumeNode["<b>Consumption tools</b><br/>Power BI, Tableau, Evidence, Dash, MCP, or other analytics apps"]
    consumeIn --> consumeNode
  end
  ingestOut --> transformIn
  transformOut --> consumeIn
  style ingestOut fill:transparent,stroke:transparent,color:transparent
  style transformIn fill:transparent,stroke:transparent,color:transparent
  style transformOut fill:transparent,stroke:transparent,color:transparent
  style consumeIn fill:transparent,stroke:transparent,color:transparent`;

if (!fakeStoreEntry) {
  throw new Error("Missing case study entry: fake-store");
}

const { Content } = await fakeStoreEntry.render();
---

<BaseLayout
  title="Fake Store Example"
  description="End-to-end Fake Store analytics case study on Axiomatic Engine."
  enableMermaid={true}
>
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        breadcrumbs={[
          { label: "Home", href: withBase("/") },
          { label: "Examples", href: withBase("/case-studies") },
          { label: "Fake Store" }
        ]}
        title="Fake Store Example"
        lede="This example shows a repeatable path from API ingestion to governed reporting outputs, with clear separation between engine runtime and BI delivery."
      >
        <img
          slot="visual"
          class="hero-visual-image"
          src={fakeStoreSalesPageImage.src}
          alt="Power BI sales dashboard screenshot for the Fake Store case study."
          width={fakeStoreSalesPageImage.width}
          height={fakeStoreSalesPageImage.height}
          loading="eager"
          decoding="async"
        />
      </PageHeader>
      <div class="case-study-actions">
        <a class="button button-primary" href={fakeStoreLinks.exampleCode} target="_blank" rel="noreferrer">
          View example code <ExternalLink size={16} strokeWidth={2} />
        </a>
        <a class="button button-secondary" href={fakeStoreLinks.pbixAsset} target="_blank" rel="noreferrer">
          View PBIX artefact <ExternalLink size={16} strokeWidth={2} />
        </a>
      </div>
    </div>
  </div>

  <div class="full-bleed glance-band">
    <section class="band-inner band-inner-wide glance-section">
      <p class="section-label">Quick overview</p>
      <SectionHeading title="At a glance" />
      <div class="glance-grid" role="list" aria-label="Case study highlights">
        <article class="glance-card" role="listitem">
          <h3>Problem</h3>
          <p>API data was easy to access but hard to govern and rerun.</p>
        </article>
        <article class="glance-card" role="listitem">
          <h3>What was built</h3>
          <p>A reusable ingestion and dbt pipeline with a reporting-ready star schema.</p>
        </article>
        <article class="glance-card" role="listitem">
          <h3>Why it matters</h3>
          <p>Reporting stays consistent because business logic lives in the model, not the dashboard.</p>
        </article>
        <article class="glance-card" role="listitem">
          <h3>Technology</h3>
          <p>Axiomatic Engine, dlt, dbt, warehouse modelling, and Power BI delivery.</p>
        </article>
      </div>
    </section>
  </div>

  <section class="architecture-section">
    <p class="section-label">Delivery architecture</p>
    <SectionHeading title="Architecture" />
    <div class="architecture-flow-layout">
      <div class="architecture-flow-left">
        <p>
          This diagram summarises the delivery flow from ingestion to warehouse modelling and then BI consumption.
        </p>
        <p>
          For clients, this creates a reliable reporting foundation where pipeline changes and dashboard changes can be managed independently.
        </p>
      </div>
      <div class="architecture-flow-right">
        <div class="mermaid">{fakeStoreTransformationMermaid}</div>
      </div>
    </div>
  </section>

  <div class="full-bleed">
    <section class="band-inner band-inner-wide reporting-section">
      <p class="section-label">Consumption layer</p>
      <SectionHeading title="Reporting outputs" />
      <p>
        Reporting assets are versioned separately from engine runtime code, so BI can evolve independently while
        staying aligned to the same warehouse contract.
      </p>
      <p>
        The PBIX artefact, semantic model assets, and screenshots show how reporting consumes the governed model in
        practice.
      </p>
      <p>
        <a class="button button-secondary" href={fakeStoreLinks.pbixAsset} target="_blank" rel="noreferrer">
          Open PBIX artefact location <ExternalLink size={16} strokeWidth={2} />
        </a>
      </p>
      <div class="gallery-preview">
        <div class="gallery-grid gallery-grid-4">
          <button class="gallery-tile" type="button" data-gallery-index="0" aria-label="Open model view screenshot">
            <img
              class="gallery-image-cover"
              src={fakeStorePbiModelImage.src}
              alt="Power BI model view for the Fake Store case study."
              width={fakeStorePbiModelImage.width}
              height={fakeStorePbiModelImage.height}
              loading="lazy"
              decoding="async"
            />
          </button>
          <button class="gallery-tile" type="button" data-gallery-index="1" aria-label="Open sales page screenshot">
            <img
              class="gallery-image-cover"
              src={fakeStoreSalesPageImage.src}
              alt="Power BI sales page for the Fake Store case study."
              width={fakeStoreSalesPageImage.width}
              height={fakeStoreSalesPageImage.height}
              loading="lazy"
              decoding="async"
            />
          </button>
        </div>
        <p class="gallery-actions">
          <button class="button button-secondary bi-gallery-open" type="button" data-open-gallery>
            View gallery
          </button>
        </p>
      </div>
      <dialog class="bi-gallery-dialog" data-gallery-dialog aria-label="Power BI image gallery">
        <form method="dialog" class="bi-gallery-close-row">
          <button class="button button-secondary" value="cancel">Close</button>
        </form>
        <figure class="bi-gallery-frame">
          <img class="bi-gallery-image" data-gallery-image alt="" />
          <figcaption class="bi-gallery-caption" data-gallery-caption></figcaption>
        </figure>
        <p class="bi-gallery-controls">
          <button class="button button-secondary" type="button" data-gallery-prev>Previous</button>
          <button class="button button-secondary" type="button" data-gallery-next>Next</button>
        </p>
      </dialog>
    </section>
  </div>

  <section>
    <p class="section-label">Reproducibility</p>
    <SectionHeading title="How to reproduce" />
    <p>
      <a class="button button-secondary" href={fakeStoreLinks.exampleCode} target="_blank" rel="noreferrer">
        Open engine project repository <ExternalLink size={16} strokeWidth={2} />
      </a>
    </p>
    <ReproSteps
      title="Execution details"
      steps={fakeStoreEntry.data.reproducibility.map((item) => item.command)}
      assumptions={fakeStoreEntry.data.assumptions}
      limitations={fakeStoreEntry.data.limitations}
    />
  </section>

  <section>
    <p class="section-label">Technical delivery detail</p>
    <SectionHeading title="Delivery intent, modelling, and transform decisions" />
    <div class="case-narrative-content">
      <Content />
    </div>
  </section>

</BaseLayout>

<script is:inline>
  const dialog = document.querySelector("[data-gallery-dialog]");
  const imageEl = document.querySelector("[data-gallery-image]");
  const captionEl = document.querySelector("[data-gallery-caption]");
  const openButton = document.querySelector("[data-open-gallery]");
  const tileButtons = document.querySelectorAll("[data-gallery-index]");
  const prevButton = document.querySelector("[data-gallery-prev]");
  const nextButton = document.querySelector("[data-gallery-next]");
  const galleryImages = Array.from(document.querySelectorAll(".gallery-grid [data-gallery-index]")).map((tile) => {
    const image = tile.querySelector("img");
    return {
      src: image?.getAttribute("src") || "",
      alt: image?.getAttribute("alt") || "",
      caption: image?.getAttribute("alt") || "BI implementation screenshot"
    };
  });

  let galleryIndex = 0;

  function renderGallery(index) {
    if (!imageEl || !captionEl) return;
    galleryIndex = (index + galleryImages.length) % galleryImages.length;
    const selected = galleryImages[galleryIndex];
    imageEl.src = selected.src;
    imageEl.alt = selected.alt;
    captionEl.textContent = selected.caption;
  }

  function openGallery(index) {
    if (!dialog) return;
    renderGallery(index);
    dialog.showModal();
  }

  openButton?.addEventListener("click", () => openGallery(0));
  prevButton?.addEventListener("click", () => renderGallery(galleryIndex - 1));
  nextButton?.addEventListener("click", () => renderGallery(galleryIndex + 1));

  tileButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const index = Number(button.getAttribute("data-gallery-index") || "0");
      openGallery(index);
    });
  });
</script>

<style>
  .case-study-actions {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0 0 1rem;
  }

  .glance-grid {
    display: grid;
    gap: 0.8rem;
    margin-top: 0.55rem;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
  }

  .glance-band {
    background: var(--bleed-band-blue);
  }

  .glance-card {
    background: color-mix(in srgb, var(--surface, #111723) 86%, transparent);
    border-radius: var(--radius-md);
    padding: 0.8rem 0.85rem;
  }

  .glance-card h3 {
    margin: 0 0 0.35rem;
    font-size: 0.98rem;
  }

  .glance-card p {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  @media (max-width: 680px) {
    .case-study-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }

  .visual-card {
    margin: 0.8rem 0 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .visual-card img {
    width: 100%;
    height: auto;
    display: block;
  }

  .architecture-flow-layout {
    display: grid;
    gap: 1rem;
    align-items: start;
    margin-top: 0.6rem;
    margin-bottom: 1.1rem;
  }

  .architecture-section {
    margin-bottom: var(--space-12);
  }

  .reporting-section {
    margin-bottom: 0;
    padding-top: clamp(2.4rem, 4vw, 3.4rem);
    padding-bottom: clamp(2.4rem, 4vw, 3.4rem);
  }

  .architecture-flow-left,
  .architecture-flow-right {
    display: grid;
    gap: 0.75rem;
    align-content: start;
  }

  .data-model-image {
    margin-top: 0;
  }

  .data-model-image figcaption {
    margin: 0;
    padding: 0.6rem 0.75rem;
    font-size: 0.84rem;
    color: var(--text-soft);
    background: color-mix(in srgb, var(--surface, #111723) 82%, transparent);
  }

  .architecture-flow-left p {
    margin: 0;
  }

  .case-narrative-content :global(h2) {
    font-size: clamp(1.02rem, 1.7vw, 1.16rem);
    margin-top: 1.1rem;
    margin-bottom: 0.45rem;
  }

  .case-narrative-content :global(h3) {
    font-size: clamp(0.94rem, 1.5vw, 1.05rem);
  }

  .case-narrative-content :global(p) {
    margin-bottom: 0.7rem;
  }

  .gallery-preview {
    margin-top: 0.5rem;
  }

  .bi-gallery-dialog {
    width: min(92vw, 1100px);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--surface, #111723) 96%, #000);
    color: var(--text);
    padding: 0.9rem;
  }

  .bi-gallery-dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
  }

  .bi-gallery-close-row {
    margin: 0 0 0.6rem;
    display: flex;
    justify-content: flex-end;
  }

  .bi-gallery-frame {
    margin: 0;
    min-height: min(70vh, 760px);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface, #111723) 88%, transparent);
    display: grid;
    place-items: center;
    padding: 0.85rem;
    gap: 0.6rem;
  }

  .bi-gallery-image {
    max-width: 100%;
    max-height: min(62vh, 680px);
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .bi-gallery-caption {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
    text-align: center;
  }

  .bi-gallery-controls {
    margin: 0.75rem 0 0;
    display: flex;
    justify-content: center;
    gap: 0.6rem;
  }

  .mermaid {
    padding-top: 0.9rem;
  }

  .mermaid :global(svg) {
    overflow: visible;
  }

  @media (min-width: 64rem) {
    .architecture-flow-layout {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }
  }

</style>
