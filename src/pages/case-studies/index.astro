---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { withBase } from "../../utils/urls";
import { ArrowRight, CheckCircle2, Microscope, Target } from "lucide-react";

const entries = await getCollection("caseStudies");
---

<BaseLayout title="Case Studies" description="Portfolio case studies with evidence and reproducibility notes.">
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        eyebrow="Case Studies"
        title="Case studies and Examples"
        lede="Each walkthrough links challenge, implementation choices, and measurable improvements in one scannable format."
      />
    </div>
  </div>

  <section>
    <SectionHeading title="How to read these case studies">
      <CheckCircle2 slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>
      Each page follows the same structure: problem context, what changed, and what improved. Technical
      details stay linked to architecture notes, commands, and implementation artefacts.
    </p>
  </section>

  <section>
    <SectionHeading title="Available case studies">
      <Target slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <div class="case-preview-grid">
      {
        entries.map((entry) => (
          <article class="case-preview-card">
            <h3>{entry.data.title}</h3>
            <dl class="case-preview-list">
              <div>
                <dt>Problem</dt>
                <dd>Fragmented source outputs and limited confidence in reporting behaviour.</dd>
              </div>
              <div>
                <dt>What changed</dt>
                <dd>{entry.data.summary}</dd>
              </div>
              <div>
                <dt>What improved</dt>
                <dd>Reproducible delivery boundaries and clearer route to decision-ready models.</dd>
              </div>
            </dl>
            <p>
              <a class="button button-secondary" href={withBase(`/case-studies/${entry.slug}`)}>
                Read case study <ArrowRight size={16} strokeWidth={2} />
              </a>
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section>
    <SectionHeading title="Comparison criteria">
      <Microscope slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>
      Pages are compared across architecture clarity, data model quality, reproducibility, and evidence
      strength. Claims map to code paths, query outputs, tests, or diagrams.
    </p>
  </section>

  <section>
    <SectionHeading title="Reproducibility standards">
      <Target slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>
      Each case study includes runnable commands, assumptions, limitations, and explicit evidence links.
      Planned capability areas are labelled clearly until supported by published artefacts.
    </p>
  </section>
</BaseLayout>
