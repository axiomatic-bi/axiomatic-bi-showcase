---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/layout/PageHeader.astro";
import SectionHeading from "../../components/layout/SectionHeading.astro";
import { withBase } from "../../utils/urls";
import { ArrowRight, Target } from "lucide-react";
import fakeStorePbiSalesImage from "../../../assets/fake-store-pbi-sales.webp";
import heroExampleImage from "../../../assets/hero-example.webp";

const entries = await getCollection("caseStudies");
---

<BaseLayout title="Examples" description="Portfolio examples with evidence and reproducibility notes.">
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        breadcrumbs={[
          { label: "Home", href: withBase("/") },
          { label: "Examples" }
        ]}
        title="Examples"
        lede="Reference builds showing how source data can be turned into trusted reporting systems, reusable models, and client-owned delivery assets."
      >
        <img
          slot="visual"
          class="hero-visual-image"
          src={heroExampleImage.src}
          alt="Examples overview visual with dashboard and model artefact motifs."
          width={heroExampleImage.width}
          height={heroExampleImage.height}
          loading="eager"
          decoding="async"
        />
      </PageHeader>
    </div>
  </div>

  <div>
    <section class="band-inner">
      <SectionHeading title="Reference Builds">
        <Target slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <div class="case-preview-grid">
        {
          entries.map((entry) => {
            const { summary, demonstrates, included } = entry.data.previewItem;
            return (
              <article class="case-preview-card">
                <div class="case-preview-card-layout">
                  <div class="case-preview-card-copy">
                    <h3>{entry.data.title}</h3>
                    <dl class="case-preview-list">
                      <div>
                        <dd>{summary}</dd>
                      </div>
                      <div>
                        <dt>What it demonstrates</dt>
                        <dd>{demonstrates}</dd>
                      </div>
                      <div>
                        <dt>Included</dt>
                        <dd>{included}</dd>
                      </div>
                    </dl>
                    <p>
                      <a class="button button-secondary" href={withBase(`/case-studies/${entry.slug}`)}>
                        Open example <ArrowRight size={16} strokeWidth={2} />
                      </a>
                    </p>
                  </div>
                  {
                    entry.slug === "fake-store" && (
                      <figure class="case-preview-card-media">
                        <img
                          src={fakeStorePbiSalesImage.src}
                          alt="Fake Store report screenshot showing sales summary visuals."
                          width={fakeStorePbiSalesImage.width}
                          height={fakeStorePbiSalesImage.height}
                          loading="lazy"
                          decoding="async"
                        />
                      </figure>
                    )
                  }
                </div>
              </article>
            );
          })
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .case-preview-card-layout {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .case-preview-card-media {
    margin: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: color-mix(in srgb, var(--surface, #111723) 84%, transparent);
  }

  .case-preview-card-media img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (min-width: 72rem) {
    .case-preview-card-layout {
      grid-template-columns: 1.2fr 1fr;
      gap: 1.25rem;
    }
  }
</style>
