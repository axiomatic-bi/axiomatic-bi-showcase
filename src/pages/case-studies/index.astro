---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";

const entries = await getCollection("caseStudies");
---

<BaseLayout title="Case Studies" description="Portfolio case studies with evidence and reproducibility notes.">
  <PageHeader
    eyebrow="Case Studies"
    title="Case Studies"
    lede="Technical walkthroughs with explicit assumptions, reproducibility steps, and trade-offs."
  />

  <section>
    <h2>Case Studies</h2>
    <p>
      Case studies document implementation choices end to end: problem framing, architecture, modelling
      decisions, validation approach, measured outcomes, and trade-offs.
    </p>
  </section>

  <section>
    <h2>Fake Store Pipeline</h2>
    <ul>
      {entries.map((entry) => <li><a href={`/case-studies/${entry.slug}`}>{entry.data.title}</a></li>)}
    </ul>
  </section>

  <section>
    <h2>Comparison Criteria</h2>
    <p>
      Pages are compared consistently across architecture clarity, data model quality, reproducibility,
      and evidence strength. Claims are expected to map to code paths, query outputs, tests, or
      diagrams.
    </p>
  </section>

  <section>
    <h2>Reproducibility Standards</h2>
    <p>
      Each case study includes runnable commands, assumptions, limitations, and explicit evidence links.
      Planned capability areas are labelled as planned until supported by published artefacts.
    </p>
  </section>
</BaseLayout>
