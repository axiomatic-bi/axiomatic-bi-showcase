---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { withBase } from "../../utils/urls";
import { ArrowRight, CheckCircle2, Microscope, Target } from "lucide-react";
import fakeStoreSalesPageImage from "../../../assets/fake-store-sales-page.webp";

const entries = await getCollection("caseStudies");
---

<BaseLayout title="Examples" description="Portfolio examples with evidence and reproducibility notes.">
  <div class="full-bleed hero-scene">
    <div class="band-inner">
      <PageHeader
        breadcrumbs={[
          { label: "Home", href: withBase("/") },
          { label: "Examples" }
        ]}
        title="Examples"
        lede="Each walkthrough links challenge, implementation choices, and measurable improvements in one scannable format."
      />
    </div>
  </div>

  <section>
    <SectionHeading title="How to read these examples">
      <CheckCircle2 slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>
      Each page follows the same structure: problem context, what changed, and what improved. Technical
      details stay linked to architecture notes, commands, and implementation artefacts.
    </p>
  </section>

  <div class="full-bleed">
    <section class="band-inner band-inner-wide examples-section">
      <SectionHeading title="Available examples">
        <Target slot="icon" size={18} strokeWidth={2} />
      </SectionHeading>
      <div class="case-preview-grid">
        {
          entries.map((entry) => (
            <article class="case-preview-card">
              <div class="case-preview-card-layout">
                <div class="case-preview-card-copy">
                  <h3>{entry.data.title}</h3>
                  <dl class="case-preview-list">
                    <div>
                      <dt>Problem</dt>
                      <dd>Fragmented source outputs and limited confidence in reporting behaviour.</dd>
                    </div>
                    <div>
                      <dt>What changed</dt>
                      <dd>{entry.data.summary}</dd>
                    </div>
                    <div>
                      <dt>What improved</dt>
                      <dd>Reproducible delivery boundaries and clearer route to decision-ready models.</dd>
                    </div>
                  </dl>
                  <p>
                    <a class="button button-secondary" href={withBase(`/case-studies/${entry.slug}`)}>
                      Open example <ArrowRight size={16} strokeWidth={2} />
                    </a>
                  </p>
                </div>
                {
                  entry.slug === "fake-store" && (
                    <figure class="case-preview-card-media">
                      <img
                        src={fakeStoreSalesPageImage.src}
                        alt="Fake Store report screenshot showing sales summary visuals."
                        width={fakeStoreSalesPageImage.width}
                        height={fakeStoreSalesPageImage.height}
                        loading="lazy"
                        decoding="async"
                      />
                    </figure>
                  )
                }
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </div>

  <section>
    <SectionHeading title="Comparison criteria">
      <Microscope slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>
      Pages are compared across architecture clarity, data model quality, reproducibility, and evidence
      strength. Claims map to code paths, query outputs, tests, or diagrams.
    </p>
  </section>

  <section>
    <SectionHeading title="Reproducibility standards">
      <Target slot="icon" size={18} strokeWidth={2} />
    </SectionHeading>
    <p>
      Each example includes runnable commands, assumptions, limitations, and explicit evidence links.
      Planned capability areas are labelled clearly until supported by published artefacts.
    </p>
  </section>
</BaseLayout>

<style>
  .examples-section {
    margin-bottom: 0;
    padding-top: clamp(2.75rem, 4.5vw, 4rem);
    padding-bottom: clamp(2.75rem, 4.5vw, 4rem);
  }

  .case-preview-card-layout {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .case-preview-card-media {
    margin: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: color-mix(in srgb, var(--surface, #111723) 84%, transparent);
  }

  .case-preview-card-media img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (min-width: 72rem) {
    .case-preview-card-layout {
      grid-template-columns: 1.2fr 1fr;
      gap: 1.25rem;
    }
  }
</style>
