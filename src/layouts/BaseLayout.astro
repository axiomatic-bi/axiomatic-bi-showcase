---
import { getCollection } from "astro:content";
import MermaidSetup from "../components/mermaid/MermaidSetup.astro";
import Footer from "../components/site/Footer.astro";
import SiteHeader from "../components/site/SiteHeader.astro";
import { stripBasePath } from "../utils/urls";
import "../styles/base.css";
import "../styles/theme.css";
import "../styles/layout.css";
import "../styles/mermaid.css";
import "../styles/components/typography.css";
import "../styles/components/buttons.css";
import "../styles/components/cards.css";
import "../styles/components/grids.css";
import "../styles/components/bands.css";
import "../styles/components/page-header.css";
import "../styles/components/content.css";

interface Props {
  title: string;
  description: string;
  enableMermaid?: boolean;
}

const { title, description, enableMermaid = false } = Astro.props;
const currentPath = Astro.url.pathname;
const routePathname = stripBasePath(currentPath);
const caseStudyEntries = (await getCollection("caseStudies"))
  .map((entry) => ({
    href: `/case-studies/${entry.slug}`,
    label: entry.data.title
  }))
  .sort((a, b) => a.label.localeCompare(b.label));

const navItems = [
  { href: "/", label: "Home" },
  { href: "/engine", label: "Engine" },
  { href: "/case-studies", label: "Examples" },
  { href: "/about", label: "About Me" },
  { href: "/contact", label: "Contact" }
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      try {
        const savedTheme = localStorage.getItem("theme");
        if (savedTheme === "light" || savedTheme === "dark") {
          document.documentElement.setAttribute("data-theme", savedTheme);
        }
      } catch {
        // Ignore storage access issues and fall back to system theme.
      }
    </script>
    {enableMermaid && <MermaidSetup />}
  </head>
  <body>
    <SiteHeader navItems={navItems} caseStudyEntries={caseStudyEntries} routePathname={routePathname} />
    <main class="container">
      <slot />
    </main>
    <Footer />
  </body>
</html>
