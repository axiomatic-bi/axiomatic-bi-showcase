---
interface Props {
  title: string;
  description: string;
  enableMermaid?: boolean;
}

const { title, description, enableMermaid = false } = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Home" },
  { href: "/engine", label: "Engine Overview" },
  { href: "/case-studies", label: "Case Studies" },
  { href: "/about", label: "About" }
];

function isActive(href: string): boolean {
  if (href === "/") {
    return currentPath === "/";
  }
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #000000;
        --surface: #05070d;
        --surface-muted: #0b1020;
        --border: #222a3d;
        --text: #eef3ff;
        --text-muted: #c2cadf;
        --brand: #7a8dff;
        --brand-contrast: #ffffff;
        --accent-blue: #5ea2ff;
        --accent-purple: #c06bff;
        --radius: 12px;
        --shadow: 0 20px 44px rgba(0, 0, 0, 0.52);
      }
      body {
        margin: 0;
        font-family: Inter, "Segoe UI", Arial, sans-serif;
        line-height: 1.65;
        background: var(--bg);
        color: var(--text);
      }
      .container {
        max-width: 1040px;
        margin: 0 auto;
        padding: 1rem 1.25rem;
      }
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(8px);
        background: color-mix(in srgb, var(--bg) 78%, transparent);
        border-bottom: 1px solid var(--border);
      }
      .site-header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.5rem 0;
      }
      nav ul {
        display: flex;
        gap: 0.5rem;
        list-style: none;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
      }
      a {
        color: var(--brand);
      }
      .nav-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.4rem 0.8rem;
        border-radius: 999px;
        border: 1px solid transparent;
        text-decoration: none;
        color: var(--text-muted);
        font-weight: 600;
      }
      .nav-link:hover {
        color: var(--text);
        background: var(--surface-muted);
        border-color: var(--border);
      }
      .nav-link[aria-current="page"] {
        background: linear-gradient(120deg, var(--accent-purple), var(--accent-blue));
        color: var(--brand-contrast);
        border-color: transparent;
      }
      main.container {
        padding-top: 1.75rem;
        padding-bottom: 2rem;
      }
      :global(h1) {
        margin: 0.2rem 0 0.5rem;
        font-size: clamp(1.85rem, 3vw, 2.45rem);
        line-height: 1.2;
        background: linear-gradient(110deg, var(--accent-blue) 5%, var(--accent-purple) 52%, #e7d8ff 95%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      :global(h2) {
        margin-top: 0;
        font-size: clamp(1.25rem, 2.2vw, 1.45rem);
      }
      :global(.section-heading) {
        display: flex;
        align-items: center;
        gap: 0.55rem;
      }
      :global(.section-heading-icon) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: auto;
        height: auto;
        border-radius: 0;
        background: none;
        backdrop-filter: none;
        color: #ffffff;
        border: 0;
        flex: 0 0 auto;
        box-shadow: none;
      }
      :global(.page-header) {
        background: radial-gradient(circle at 20% 10%, rgba(82, 127, 255, 0.14), transparent 48%),
          radial-gradient(circle at 90% 24%, rgba(182, 107, 255, 0.16), transparent 40%),
          linear-gradient(165deg, #070a13, #03050b);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 1.2rem 1.2rem 1rem;
        margin: 0 0 1rem;
      }
      :global(.page-header-content) {
        display: grid;
        grid-template-columns: 1.5fr minmax(150px, 0.8fr);
        gap: 1rem;
        align-items: center;
      }
      :global(.page-header-copy p) {
        max-width: 64ch;
      }
      :global(.page-header-visual) {
        display: flex;
        justify-content: flex-end;
        align-items: center;
      }
      :global(.hero-visual-image) {
        width: clamp(140px, 28vw, 210px);
        height: auto;
        aspect-ratio: 1 / 1;
        object-fit: contain;
        display: block;
        border-radius: 16px;
        border: 1px solid color-mix(in srgb, var(--accent-blue) 28%, var(--border));
        box-shadow: 0 0 0 1px rgba(140, 177, 255, 0.32), 0 16px 38px rgba(90, 76, 255, 0.32);
      }
      :global(.page-header .eyebrow) {
        display: inline-flex;
        margin: 0;
        padding: 0.18rem 0.55rem;
        border-radius: 999px;
        background: linear-gradient(
          140deg,
          color-mix(in srgb, var(--accent-purple) 35%, transparent),
          color-mix(in srgb, var(--accent-blue) 35%, transparent)
        );
        border: 1px solid color-mix(in srgb, var(--accent-blue) 22%, var(--border));
        color: #ebf1ff;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.02em;
      }
      :global(p),
      :global(li) {
        color: var(--text-muted);
      }
      :global(section) {
        background: transparent;
        border: 0;
        border-radius: 0;
        box-shadow: none;
        padding: 0.6rem 0 1.1rem;
        margin: 0 0 2rem;
        border-bottom: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
      }
      :global(section:last-of-type) {
        margin-bottom: 0;
        padding-bottom: 0;
        border-bottom: 0;
      }
      :global(.icon-card-grid) {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 0.75rem;
      }
      :global(.icon-card) {
        background: linear-gradient(180deg, color-mix(in srgb, var(--surface-muted) 92%, black), var(--surface-muted));
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.85rem 0.9rem;
      }
      :global(.icon-card-icon) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 8px;
        margin-bottom: 0.45rem;
        background: linear-gradient(
          140deg,
          color-mix(in srgb, var(--accent-blue) 30%, transparent),
          color-mix(in srgb, var(--accent-purple) 30%, transparent)
        );
        backdrop-filter: blur(8px);
        color: #dae3ff;
        border: 1px solid color-mix(in srgb, var(--accent-purple) 22%, var(--border));
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
      }
      :global(.icon-card h3) {
        margin: 0 0 0.3rem;
        font-size: 1rem;
        color: var(--text);
      }
      :global(.icon-card p) {
        margin: 0;
      }
      :global(code) {
        background: var(--surface-muted);
        padding: 0.1rem 0.35rem;
        border-radius: 6px;
      }
      :global(pre) {
        background: var(--surface-muted);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.75rem;
        overflow-x: auto;
      }
      :global(.button) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        border-radius: 10px;
        padding: 0.55rem 0.9rem;
        text-decoration: none;
        font-weight: 600;
        border: 1px solid color-mix(in srgb, var(--accent-blue) 24%, var(--border));
        color: #f2f6ff;
        background: linear-gradient(
          130deg,
          color-mix(in srgb, var(--accent-purple) 28%, #0a1020),
          color-mix(in srgb, var(--accent-blue) 30%, #0a1020)
        );
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04), 0 10px 24px rgba(23, 17, 43, 0.42);
      }
      :global(.button-primary) {
        background: linear-gradient(120deg, #7b5cff, #5f95ff);
        border-color: color-mix(in srgb, #90b3ff 35%, transparent);
      }
      :global(.button-primary:hover) {
        filter: brightness(1.08);
        transform: translateY(-1px);
      }
      :global(.button-secondary) {
        background: linear-gradient(
          130deg,
          color-mix(in srgb, var(--accent-purple) 18%, #080c18),
          color-mix(in srgb, var(--accent-blue) 20%, #080c18)
        );
        color: #dee7ff;
      }
      :global(.button-secondary:hover) {
        filter: brightness(1.06);
        transform: translateY(-1px);
      }
      .mermaid {
        background: var(--surface-muted);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.8rem;
        margin-top: 0.8rem;
        overflow-x: auto;
      }
      :global(.mermaid svg) {
        max-width: 100%;
        height: auto;
      }
      .site-footer {
        border-top: 1px solid var(--border);
      }
      .site-footer .container {
        padding-top: 1.3rem;
        padding-bottom: 1.3rem;
      }
      @media (max-width: 860px) {
        :global(.page-header-content) {
          grid-template-columns: 1fr;
        }
        :global(.page-header-visual) {
          justify-content: center;
          margin-top: 0.35rem;
        }
        :global(.hero-visual-image) {
          width: min(220px, 70vw);
        }
      }
    </style>
    {
      enableMermaid && (
        <script type="module" is:inline>
          import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
          const isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const themeConfig = isDark
            ? {
                theme: "base",
                themeVariables: {
                  background: "#111a2c",
                  primaryColor: "#162136",
                  secondaryColor: "#111a2c",
                  tertiaryColor: "#0b1220",
                  primaryTextColor: "#e6edf7",
                  secondaryTextColor: "#e6edf7",
                  tertiaryTextColor: "#e6edf7",
                  primaryBorderColor: "#4b5e83",
                  lineColor: "#9cb0d1",
                  fontFamily: "Inter, Segoe UI, Arial, sans-serif"
                }
              }
            : {
                theme: "base",
                themeVariables: {
                  background: "#ffffff",
                  primaryColor: "#eff6ff",
                  secondaryColor: "#f8fafc",
                  tertiaryColor: "#ffffff",
                  primaryTextColor: "#0f172a",
                  secondaryTextColor: "#0f172a",
                  tertiaryTextColor: "#0f172a",
                  primaryBorderColor: "#8aa3d1",
                  lineColor: "#475569",
                  fontFamily: "Inter, Segoe UI, Arial, sans-serif"
                }
              };
          mermaid.initialize({
            startOnLoad: true,
            securityLevel: "strict",
            flowchart: { useMaxWidth: true, htmlLabels: false, curve: "linear" },
            ...themeConfig
          });
        </script>
      )
    }
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header-inner">
        <a class="nav-link" href="/">Axiomatic BI Showcase</a>
        <nav aria-label="Primary">
          <ul>
            {
              navItems.map((item) => (
                <li>
                  <a class="nav-link" href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <small>Axiomatic BI Showcase</small>
      </div>
    </footer>
  </body>
</html>
