---
import { getCollection } from "astro:content";
import { stripBasePath, withBase } from "../utils/urls";

interface Props {
  title: string;
  description: string;
  enableMermaid?: boolean;
}

const { title, description, enableMermaid = false } = Astro.props;
const currentPath = Astro.url.pathname;
const routePathname = stripBasePath(currentPath);
const caseStudyEntries = (await getCollection("caseStudies"))
  .map((entry) => ({
    href: `/case-studies/${entry.slug}`,
    label: entry.data.title
  }))
  .sort((a, b) => a.label.localeCompare(b.label));
const navItems = [
  { href: "/", label: "Home" },
  { href: "/engine", label: "Engine" },
  { href: "/case-studies", label: "Examples" },
  { href: "/about", label: "About Me" },
  { href: "/contact", label: "Contact" }
];

function isActive(href: string): boolean {
  if (href.includes("#")) {
    return false;
  }
  const routePath = href.split("#")[0] ?? href;
  if (routePath === "/about") {
    return routePathname === "/about";
  }
  if (href === "/") {
    return routePathname === "/";
  }
  return routePathname === routePath || routePathname.startsWith(`${routePath}/`);
}
---

