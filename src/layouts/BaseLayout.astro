---
import { getCollection } from "astro:content";
import { stripBasePath, withBase } from "../utils/urls";

interface Props {
  title: string;
  description: string;
  enableMermaid?: boolean;
}

const { title, description, enableMermaid = false } = Astro.props;
const currentPath = Astro.url.pathname;
const routePathname = stripBasePath(currentPath);
const caseStudyEntries = (await getCollection("caseStudies"))
  .map((entry) => ({
    href: `/case-studies/${entry.slug}`,
    label: entry.data.title
  }))
  .sort((a, b) => a.label.localeCompare(b.label));
const navItems = [
  { href: "/", label: "Home" },
  { href: "/engine", label: "Engine" },
  { href: "/case-studies", label: "Case Studies" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" }
];

function isActive(href: string): boolean {
  if (href.includes("#")) {
    return false;
  }
  const routePath = href.split("#")[0] ?? href;
  if (routePath === "/about") {
    return routePathname === "/about";
  }
  if (href === "/") {
    return routePathname === "/";
  }
  return routePathname === routePath || routePathname.startsWith(`${routePath}/`);
}
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark light;
        --bg: #080b11;
        --surface: #111723;
        --surface-soft: #161d2b;
        --surface-subtle: #1b2436;
        --border: #2a344a;
        --border-strong: #3b4966;
        --text: #e8edf7;
        --text-muted: #b9c4d8;
        --text-soft: #96a4c0;
        --accent: #7b8dff;
        --accent-strong: #96a5ff;
        --accent-soft: rgba(123, 141, 255, 0.18);
        --accent-contrast: #ffffff;
        --radius-sm: 10px;
        --radius-md: 14px;
        --radius-lg: 18px;
        --space-1: 0.25rem;
        --space-2: 0.5rem;
        --space-3: 0.75rem;
        --space-4: 1rem;
        --space-5: 1.25rem;
        --space-6: 1.5rem;
        --space-8: 2rem;
        --space-10: 2.5rem;
        --space-12: 3rem;
        --space-14: 3.5rem;
        --space-16: 4rem;
        --section-gap: clamp(4.5rem, 7vw, 6.5rem);
        --content-max-width: 1140px;
        --band-max-width: 1140px;
        --band-wide-max-width: 1232px;
        --hero-max-width: 1280px;
        --shadow-soft: 0 18px 34px rgba(2, 8, 20, 0.38);
      }
      @media (prefers-color-scheme: light) {
        :root {
          --bg: #f4f6fb;
          --surface: #ffffff;
          --surface-soft: #f9faff;
          --surface-subtle: #eef2fd;
          --border: #d5ddf0;
          --border-strong: #bec9e3;
          --text: #111a2e;
          --text-muted: #3a4864;
          --text-soft: #5a6783;
          --accent: #4f5ffd;
          --accent-strong: #3b4cf8;
          --accent-soft: rgba(79, 95, 253, 0.12);
          --accent-contrast: #ffffff;
          --shadow-soft: 0 16px 30px rgba(48, 64, 109, 0.12);
        }
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: Inter, "Segoe UI", Arial, sans-serif;
        line-height: 1.55;
        background: var(--bg);
        color: var(--text);
      }
      .container {
        max-width: var(--content-max-width);
        margin: 0 auto;
        padding: var(--space-4) var(--space-5);
      }
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(10px);
        background: color-mix(in srgb, var(--bg) 84%, transparent);
        border-bottom: 1px solid var(--border);
      }
      .site-header .container {
        max-width: var(--hero-max-width);
      }
      .site-header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
        padding: var(--space-2) 0;
      }
      nav ul {
        display: flex;
        gap: var(--space-2);
        list-style: none;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
      }
      .nav-item-dropdown {
        position: relative;
      }
      .nav-dropdown {
        position: absolute;
        top: calc(100% + 0.35rem);
        left: 0;
        min-width: 240px;
        padding: var(--space-2);
        margin: 0;
        border-radius: var(--radius-md);
        border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
        background: color-mix(in srgb, var(--surface) 94%, var(--bg));
        box-shadow: var(--shadow-soft);
        display: grid;
        gap: var(--space-1);
        list-style: none;
        z-index: 20;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-4px);
        transition: opacity 120ms ease, transform 120ms ease, visibility 120ms ease;
      }
      .nav-item-dropdown:hover .nav-dropdown,
      .nav-item-dropdown:focus-within .nav-dropdown {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }
      .nav-dropdown-link {
        display: block;
        width: 100%;
        border-radius: var(--radius-sm);
        padding: 0.42rem 0.55rem;
        text-decoration: none;
        color: var(--text-muted);
        font-size: 0.9rem;
      }
      .nav-dropdown-link:hover,
      .nav-dropdown-link:focus-visible {
        color: var(--text);
        background: var(--surface-soft);
        outline: none;
      }
      a {
        color: var(--accent);
      }
      .nav-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.44rem 0.76rem;
        border-radius: 999px;
        border: 1px solid var(--border);
        text-decoration: none;
        color: var(--text-muted);
        font-weight: 500;
        transition: background-color 140ms ease, border-color 140ms ease, color 140ms ease;
      }
      .nav-link:hover {
        color: var(--text);
        background: var(--surface-soft);
        border-color: var(--border-strong);
      }
      .nav-link:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      .nav-link[aria-current="page"] {
        background: var(--accent-soft);
        color: var(--text);
        border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
      }
      main.container {
        padding-top: 0;
        padding-bottom: var(--space-12);
      }
      :global(.full-bleed) {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
      }
      :global(.band-inner) {
        max-width: var(--band-max-width);
        margin: 0 auto;
        padding: var(--space-14) var(--space-5);
      }
      :global(.band-inner-wide) {
        max-width: var(--band-wide-max-width);
      }
      :global(.band-inner-tight) {
        padding-top: var(--space-8);
        padding-bottom: var(--space-8);
      }
      :global(h1) {
        margin: 0;
        font-size: clamp(2rem, 4.4vw, 3rem);
        line-height: 1.08;
        color: var(--text);
        letter-spacing: -0.02em;
      }
      :global(h2) {
        margin-top: 0;
        margin-bottom: var(--space-3);
        font-size: clamp(1.32rem, 2.8vw, 1.86rem);
        line-height: 1.22;
        letter-spacing: -0.01em;
      }
      :global(h3) {
        margin: 0 0 var(--space-2);
        font-size: 1.05rem;
        line-height: 1.35;
      }
      :global(.section-heading) {
        margin-bottom: var(--space-3);
      }
      :global(.page-header) {
        background: none;
        border: 0;
        border-radius: 0;
        box-shadow: none;
        padding: 0;
        margin: 0;
      }
      :global(.hero-scene .page-header h1) {
        font-size: clamp(2.8rem, 7vw, 5rem);
        line-height: 1.02;
        letter-spacing: -0.03em;
        margin-bottom: var(--space-4);
      }
      :global(.hero-scene .page-header-copy p) {
        max-width: 52ch;
      }
      :global(.page-header-content) {
        display: grid;
        grid-template-columns: 1.35fr minmax(220px, 1fr);
        gap: var(--space-6);
        align-items: center;
      }
      :global(.page-header-copy) {
        max-width: 65ch;
      }
      :global(.page-header-copy p) {
        max-width: 55ch;
      }
      :global(.page-header-visual) {
        display: flex;
        justify-content: flex-end;
        align-items: center;
      }
      :global(.hero-visual-image) {
        width: clamp(420px, 50vw, 680px);
        max-width: 100%;
        height: auto;
        aspect-ratio: auto;
        object-fit: initial;
        display: block;
        border-radius: var(--radius-md);
        border: 1px solid color-mix(in srgb, var(--accent) 32%, var(--border));
        box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 24%, transparent), var(--shadow-soft);
      }
      :global(.hero-visual-frame) {
        width: clamp(220px, 32vw, 360px);
        aspect-ratio: 1 / 1;
        border-radius: var(--radius-md);
        border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--border));
        background:
          radial-gradient(circle at 20% 18%, color-mix(in srgb, var(--accent) 24%, transparent), transparent 40%),
          linear-gradient(165deg, color-mix(in srgb, var(--surface) 86%, var(--accent-soft)), var(--surface));
        position: relative;
        box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 22%, transparent), var(--shadow-soft);
        overflow: hidden;
      }
      :global(.hero-visual-node) {
        position: absolute;
        border-radius: var(--radius-sm);
        border: 1px solid color-mix(in srgb, var(--border) 74%, transparent);
        background: color-mix(in srgb, var(--surface-soft) 72%, transparent);
      }
      :global(.hero-visual-node-source) {
        width: 42%;
        height: 20%;
        left: 9%;
        top: 18%;
      }
      :global(.hero-visual-node-model) {
        width: 54%;
        height: 26%;
        right: 10%;
        top: 38%;
        background: color-mix(in srgb, var(--surface-soft) 62%, var(--accent-soft));
      }
      :global(.hero-visual-node-report) {
        width: 36%;
        height: 18%;
        left: 18%;
        bottom: 14%;
      }
      :global(.page-header .eyebrow) {
        display: none;
      }
      :global(.page-breadcrumbs) {
        margin: 0 0 var(--space-3);
      }
      :global(.page-breadcrumbs ol) {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin: 0;
        padding: 0;
      }
      :global(.page-breadcrumbs li) {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: color-mix(in srgb, var(--text-soft) 86%, var(--text-muted));
        font-size: 0.82rem;
      }
      :global(.page-breadcrumbs li + li::before) {
        content: "›";
        color: color-mix(in srgb, var(--text-soft) 75%, transparent);
      }
      :global(.page-breadcrumbs a) {
        color: color-mix(in srgb, var(--text-soft) 88%, var(--text-muted));
        text-decoration: none;
      }
      :global(.page-breadcrumbs a:hover) {
        color: var(--text);
        text-decoration: underline;
      }
      :global(.page-breadcrumbs li:last-child span) {
        color: var(--text);
        font-weight: 600;
      }
      :global(.section-label) {
        margin: 0 0 var(--space-2);
        color: var(--accent-strong);
        letter-spacing: 0.04em;
        text-transform: uppercase;
        font-size: 0.75rem;
        font-weight: 600;
      }
      :global(.section-intro) {
        margin-top: 0;
        max-width: 60ch;
      }
      :global(p),
      :global(li) {
        color: var(--text-muted);
        margin-top: 0;
      }
      :global(section) {
        background: transparent;
        border: 0;
        border-radius: 0;
        box-shadow: none;
        padding: 0;
        margin: 0 0 var(--section-gap);
      }
      :global(.full-bleed + section) {
        padding-top: clamp(1.5rem, 3vw, 2.25rem);
      }
      :global(section + .full-bleed) {
        margin-top: clamp(1.25rem, 2.4vw, 2rem);
      }
      :global(.section-before-band) {
        margin-bottom: 0;
        padding-bottom: clamp(1.5rem, 2.8vw, 2.25rem);
      }
      :global(section:last-of-type) {
        margin-bottom: 0;
      }
      :global(.hero-actions) {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
        margin: var(--space-6) 0 var(--space-3);
      }
      :global(.hero-proofline) {
        margin-bottom: var(--space-6);
        color: var(--text-soft);
      }
      :global(.hero-scene) {
        background:
          radial-gradient(circle at 15% 20%, rgba(123, 141, 255, 0.22), transparent 40%),
          radial-gradient(circle at 85% 5%, rgba(123, 141, 255, 0.18), transparent 32%),
          linear-gradient(180deg, #0b1220 0%, #0a0f1b 60%, #090d17 100%);
        border-bottom: 1px solid color-mix(in srgb, var(--border) 78%, transparent);
        margin-bottom: 0;
      }
      :global(.hero-scene .band-inner) {
        max-width: var(--hero-max-width);
        padding-top: var(--space-16);
        padding-bottom: var(--space-12);
      }
      :global(.hero-highlight-list) {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
        margin: 0;
        padding: 0;
      }
      :global(.hero-highlight-list li) {
        background: transparent;
        border: 1px solid color-mix(in srgb, var(--border) 58%, transparent);
        color: var(--text-muted);
        border-radius: 999px;
        padding: 0.35rem 0.72rem;
        font-size: 0.82rem;
        line-height: 1.2;
        font-weight: 500;
      }
      :global(.proof-band) {
        background: color-mix(in srgb, var(--surface) 48%, transparent);
      }
      :global(.proof-band .band-inner) {
        padding-block: clamp(2.5rem, 5vw, 4rem);
      }
      :global(.proof-band .proof-strip) {
        padding-top: 0;
        margin-bottom: 0;
      }
      :global(.proof-strip) {
        padding: var(--space-2) 0 0;
        border-radius: 0;
        border: 0;
        background: transparent;
        margin-bottom: var(--space-14);
      }
      :global(.proof-chip-list) {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
        margin: var(--space-4) 0 0;
        padding: 0;
      }
      :global(.proof-chip) {
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        border: 1px solid color-mix(in srgb, var(--border) 58%, transparent);
        background: transparent;
        color: var(--text-muted);
        font-size: 0.82rem;
        font-weight: 500;
      }
      :global(.tonal-band) {
        background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--surface-soft) 56%, transparent));
      }
      :global(.problem-grid) {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1fr;
        gap: var(--space-4);
      }
      :global(.problem-card) {
        padding: var(--space-5);
        border-radius: var(--radius-md);
        border: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
        background: color-mix(in srgb, var(--surface) 82%, transparent);
      }
      :global(.problem-card-featured) {
        background: color-mix(in srgb, var(--surface) 78%, var(--accent-soft));
      }
      :global(.problem-icon) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--space-3);
        width: 2rem;
        height: 2rem;
        border-radius: var(--radius-sm);
        border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--border));
        background: var(--surface-soft);
        color: var(--accent-strong);
      }
      :global(.outcome-grid) {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: var(--space-4);
      }
      :global(.outcome-card-stack) {
        display: grid;
        gap: var(--space-4);
      }
      :global(.outcome-card) {
        padding: var(--space-5);
        border-radius: var(--radius-md);
        border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
        background: color-mix(in srgb, var(--surface) 76%, transparent);
      }
      :global(.outcome-card-featured) {
        background: color-mix(in srgb, var(--surface) 72%, var(--accent-soft));
      }
      :global(.deliverable-tags) {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
        margin: var(--space-4) 0 0;
        padding: 0;
      }
      :global(.deliverable-tags li) {
        color: var(--text-muted);
        border: 1px solid color-mix(in srgb, var(--border) 58%, transparent);
        border-radius: 999px;
        padding: 0.3rem 0.66rem;
        font-size: 0.82rem;
        font-weight: 500;
        background: transparent;
      }
      :global(.engine-band) {
        background:
          radial-gradient(circle at 85% 25%, rgba(123, 141, 255, 0.12), transparent 38%),
          linear-gradient(180deg, #0b101c, #0c1220);
        border-top: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
        border-bottom: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
      }
      :global(.engine-overview) {
        display: grid;
        grid-template-columns: 1fr 1.1fr;
        gap: var(--space-5);
        align-items: start;
      }
      :global(.proof-grid) {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: var(--space-4);
      }
      :global(.proof-card) {
        padding: var(--space-5);
        border-radius: var(--radius-md);
        border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
        background: color-mix(in srgb, var(--surface) 82%, transparent);
      }
      :global(.case-preview-grid) {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: var(--space-4);
      }
      :global(.case-preview-card) {
        padding: var(--space-5);
        border-radius: var(--radius-md);
        border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
        background: color-mix(in srgb, var(--surface) 84%, transparent);
      }
      :global(.case-preview-list) {
        margin: 0 0 var(--space-4);
      }
      :global(.case-preview-list div) {
        margin-bottom: var(--space-3);
      }
      :global(.case-preview-list dt) {
        font-size: 0.78rem;
        color: var(--accent-strong);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: var(--space-1);
      }
      :global(.case-preview-list dd) {
        margin: 0;
        color: var(--text-muted);
      }
      :global(.evidence-list) {
        list-style: none;
        padding: 0;
        margin: var(--space-4) 0 0;
        display: grid;
        gap: var(--space-3);
      }
      :global(.evidence-item) {
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        background: var(--surface);
        padding: var(--space-4);
      }
      :global(.evidence-label) {
        margin-bottom: var(--space-2);
      }
      :global(.evidence-type) {
        display: inline-block;
        margin-left: var(--space-2);
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--accent-strong);
      }
      :global(.evidence-links) {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
        margin-top: var(--space-3);
      }
      :global(.reporting-layout) {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: var(--space-4);
      }
      :global(.reporting-band) {
        background:
          radial-gradient(circle at 20% 15%, rgba(123, 141, 255, 0.14), transparent 35%),
          linear-gradient(180deg, #0d1424 0%, #0b1220 100%);
      }
      :global(.reporting-visual) {
        border: 1px solid color-mix(in srgb, var(--border) 66%, transparent);
        border-radius: var(--radius-md);
        background: color-mix(in srgb, var(--surface) 84%, transparent);
        padding: var(--space-4);
        box-shadow: var(--shadow-soft);
      }
      :global(.report-header-bar) {
        height: 0.7rem;
        width: 45%;
        border-radius: 999px;
        background: var(--accent-soft);
        margin-bottom: var(--space-4);
      }
      :global(.report-panels) {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: var(--space-3);
      }
      :global(.report-panel) {
        min-height: 88px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        background: var(--surface-soft);
      }
      :global(.report-panel-large) {
        grid-column: 1 / -1;
        min-height: 148px;
        background: color-mix(in srgb, var(--surface-soft) 80%, var(--accent-soft));
      }
      :global(.reporting-callouts) {
        display: grid;
        gap: var(--space-4);
      }
      :global(.reporting-note) {
        border: 1px solid color-mix(in srgb, var(--border) 66%, transparent);
        border-radius: var(--radius-md);
        background: color-mix(in srgb, var(--surface) 82%, transparent);
        padding: var(--space-5);
      }
      :global(.process-band) {
        background: color-mix(in srgb, var(--surface-soft) 44%, transparent);
      }
      :global(.process-grid) {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: var(--space-4);
      }
      :global(.process-card) {
        padding: var(--space-4) 0;
        border: 0;
        border-top: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
        border-radius: 0;
        background: transparent;
      }
      :global(.process-index) {
        color: var(--accent-strong);
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: var(--space-2);
      }
      :global(.roadmap-callout) {
        background: transparent;
        border: 0;
        border-radius: 0;
        padding: var(--space-2) 0;
        margin: 0;
      }
      :global(.roadmap-band) {
        background: linear-gradient(
          180deg,
          color-mix(in srgb, var(--surface-soft) 48%, transparent),
          color-mix(in srgb, var(--surface-soft) 28%, transparent)
        );
        border-top: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
        border-bottom: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
      }
      :global(.cta-band) {
        background: linear-gradient(180deg, color-mix(in srgb, var(--accent-soft) 50%, transparent), transparent);
        border-top: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
        margin-top: var(--space-14);
      }
      :global(.final-cta-inner) {
        max-width: var(--band-max-width);
        margin: 0 auto;
        padding: var(--space-12) var(--space-5);
      }
      :global(.final-cta) {
        border: 0;
        border-radius: 0;
        padding: 0;
        margin: 0;
        background: transparent;
      }
      :global(.icon-card-grid) {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: var(--space-3);
      }
      :global(.icon-card) {
        background: color-mix(in srgb, var(--surface) 84%, transparent);
        border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
        border-radius: var(--radius-md);
        padding: var(--space-4);
      }
      :global(.icon-card-icon) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: var(--radius-sm);
        margin-bottom: var(--space-2);
        background: var(--accent-soft);
        color: var(--accent-strong);
        border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--border));
      }
      :global(.icon-card h3) {
        margin: 0 0 var(--space-2);
        font-size: 1rem;
        color: var(--text);
      }
      :global(.icon-card p) {
        margin: 0;
      }
      :global(code) {
        background: var(--surface-subtle);
        padding: 0.12rem 0.36rem;
        border-radius: 6px;
      }
      :global(pre) {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: var(--space-3);
        overflow-x: auto;
      }
      :global(.button) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2);
        border-radius: var(--radius-sm);
        padding: 0.58rem 0.92rem;
        text-decoration: none;
        font-weight: 600;
        border: 1px solid var(--border-strong);
        color: var(--text);
        background: var(--surface-soft);
        transition: transform 120ms ease, border-color 120ms ease, background-color 120ms ease;
      }
      :global(.button-primary) {
        background: var(--accent);
        border-color: color-mix(in srgb, var(--accent) 70%, var(--border));
        color: var(--accent-contrast);
      }
      :global(.button-secondary) {
        background: var(--surface-soft);
        border-color: color-mix(in srgb, var(--accent) 38%, var(--border));
        color: var(--text);
      }
      :global(.button:hover) {
        transform: translateY(-1px);
        border-color: color-mix(in srgb, var(--accent) 46%, var(--border));
      }
      :global(.button-primary:hover) {
        background: color-mix(in srgb, var(--accent) 72%, #ffffff 28%);
        color: #0b1020;
      }
      :global(.button:focus-visible) {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      :global(.button-secondary:hover) {
        background: color-mix(in srgb, var(--accent-soft) 42%, var(--surface-soft) 58%);
        color: var(--text);
        border-color: color-mix(in srgb, var(--accent) 62%, var(--border));
      }
      :global(.gallery-preview) {
        border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
        border-radius: var(--radius-md);
        background: color-mix(in srgb, var(--surface) 84%, transparent);
        padding: var(--space-3);
        display: grid;
        gap: var(--space-3);
      }
      :global(.gallery-grid) {
        display: grid;
        gap: var(--space-2);
      }
      :global(.gallery-grid-4) {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
      :global(.gallery-tile) {
        width: 100%;
        aspect-ratio: 1 / 1;
        border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
        border-radius: var(--radius-sm);
        background: color-mix(in srgb, var(--surface-soft) 88%, transparent);
        overflow: hidden;
        display: grid;
        place-items: center;
        padding: 0;
      }
      :global(button.gallery-tile) {
        cursor: pointer;
      }
      :global(.gallery-image-cover) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      :global(.gallery-tile-placeholder) {
        color: var(--text-soft);
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        border-style: dashed;
      }
      :global(.gallery-actions) {
        margin: 0;
        display: flex;
        justify-content: flex-end;
      }
      .mermaid {
        background: color-mix(in srgb, var(--surface) 85%, transparent);
        border: 1px solid color-mix(in srgb, var(--border) 66%, transparent);
        border-radius: var(--radius-md);
        padding: var(--space-4);
        margin-top: 0;
        overflow-x: auto;
      }
      :global(.mermaid svg) {
        max-width: 100%;
        height: auto;
      }
      :global(.mermaid .node rect),
      :global(.mermaid .node polygon),
      :global(.mermaid .node path),
      :global(.mermaid .cluster rect) {
        rx: 10px;
        ry: 10px;
      }
      .site-footer {
        border-top: 1px solid var(--border);
      }
      .site-footer .container {
        padding-top: var(--space-6);
        padding-bottom: var(--space-6);
      }
      .site-footer small {
        color: var(--text-soft);
      }
      @media (max-width: 860px) {
        :global(.band-inner) {
          padding-top: var(--space-12);
          padding-bottom: var(--space-12);
        }
        :global(.page-header-content) {
          grid-template-columns: 1fr;
        }
        :global(.page-header-visual) {
          justify-content: center;
          margin-top: 0.35rem;
        }
        :global(.hero-visual-image) {
          width: min(520px, 92vw);
        }
        :global(.hero-visual-frame) {
          width: min(280px, 72vw);
        }
        :global(.engine-overview),
        :global(.reporting-layout),
        :global(.outcome-grid) {
          grid-template-columns: 1fr;
        }
        :global(.problem-grid) {
          grid-template-columns: 1fr;
        }
        :global(.proof-grid) {
          grid-template-columns: 1fr;
        }
        :global(.process-grid) {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }
      @media (max-width: 640px) {
        .container {
          padding: var(--space-4);
        }
        :global(.band-inner) {
          padding: var(--space-10) var(--space-4);
        }
        :global(.page-header) {
          padding: var(--space-5);
        }
        :global(.final-cta-inner) {
          padding: var(--space-10) var(--space-4);
        }
        :global(.process-grid) {
          grid-template-columns: 1fr;
        }
        :global(.gallery-grid-4) {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }
    </style>
    {
      enableMermaid && (
        <script type="module" is:inline>
          import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
          const isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const themeConfig = isDark
            ? {
                theme: "base",
                themeVariables: {
                  background: "#111a2c",
                  primaryColor: "#162136",
                  secondaryColor: "#111a2c",
                  tertiaryColor: "#0b1220",
                  borderRadius: 10,
                  primaryTextColor: "#e6edf7",
                  secondaryTextColor: "#e6edf7",
                  tertiaryTextColor: "#e6edf7",
                  primaryBorderColor: "#4b5e83",
                  lineColor: "#9cb0d1",
                  fontFamily: "Inter, Segoe UI, Arial, sans-serif"
                }
              }
            : {
                theme: "base",
                themeVariables: {
                  background: "#ffffff",
                  primaryColor: "#eff6ff",
                  secondaryColor: "#f8fafc",
                  tertiaryColor: "#ffffff",
                  borderRadius: 10,
                  primaryTextColor: "#0f172a",
                  secondaryTextColor: "#0f172a",
                  tertiaryTextColor: "#0f172a",
                  primaryBorderColor: "#8aa3d1",
                  lineColor: "#475569",
                  fontFamily: "Inter, Segoe UI, Arial, sans-serif"
                }
              };
          mermaid.initialize({
            startOnLoad: true,
            securityLevel: "strict",
            flowchart: { useMaxWidth: true, htmlLabels: false, curve: "linear" },
            ...themeConfig
          });
        </script>
      )
    }
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header-inner">
        <a class="nav-link" href={withBase("/")}>Axiomatic BI Showcase</a>
        <nav aria-label="Primary">
          <ul>
            {
              navItems.map((item) => (
                item.href === "/case-studies" ? (
                  <li class="nav-item-dropdown">
                    <a class="nav-link" href={withBase(item.href)} aria-current={isActive(item.href) ? "page" : undefined}>
                      {item.label}
                    </a>
                    {caseStudyEntries.length > 0 && (
                      <ul class="nav-dropdown" aria-label="Case study pages">
                        {caseStudyEntries.map((entry) => (
                          <li>
                            <a class="nav-dropdown-link" href={withBase(entry.href)}>
                              {entry.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                ) : (
                  <li>
                    <a class="nav-link" href={withBase(item.href)} aria-current={isActive(item.href) ? "page" : undefined}>
                      {item.label}
                    </a>
                  </li>
                )
              ))
            }
          </ul>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <small>Axiomatic BI Showcase</small>
      </div>
    </footer>
  </body>
</html>
