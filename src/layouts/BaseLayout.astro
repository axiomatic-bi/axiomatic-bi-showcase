        font-size: clamp(1.32rem, 2.8vw, 1.86rem);
        line-height: 1.22;
        letter-spacing: -0.01em;
      }
      :global(h3) {
        margin: 0 0 var(--space-2);
        font-size: 1.05rem;
        line-height: 1.35;
      }
      :global(.section-heading) {
