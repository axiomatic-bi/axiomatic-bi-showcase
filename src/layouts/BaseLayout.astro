        background: none;
        border: 0;
        border-radius: 0;
        box-shadow: none;
        padding: 0;
        margin: 0;
      }
      :global(.hero-scene .page-header h1) {
        font-size: clamp(2.8rem, 7vw, 5rem);
        line-height: 1.02;
        letter-spacing: -0.03em;
        margin-bottom: var(--space-4);
      }
      :global(.hero-scene .page-header-copy p) {
        max-width: 52ch;
      }
