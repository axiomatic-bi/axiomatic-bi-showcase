---
interface Props {
  title: string;
  description: string;
  enableMermaid?: boolean;
}

const { title, description, enableMermaid = false } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: light dark;
      }
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        line-height: 1.5;
      }
      .container {
        max-width: 960px;
        margin: 0 auto;
        padding: 1rem;
      }
      header,
      footer {
        border-bottom: 1px solid #7773;
      }
      footer {
        border-top: 1px solid #7773;
        border-bottom: 0;
        margin-top: 2rem;
      }
      nav ul {
        display: flex;
        gap: 1rem;
        list-style: none;
        padding: 0;
        margin: 0.75rem 0;
        flex-wrap: wrap;
      }
      a {
        text-underline-offset: 0.2rem;
      }
      .mermaid {
        overflow-x: auto;
      }
    </style>
    {
      enableMermaid && (
        <script type="module" is:inline>
          import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
          mermaid.initialize({ startOnLoad: true, securityLevel: "strict" });
        </script>
      )
    }
  </head>
  <body>
    <header>
      <div class="container">
        <nav aria-label="Primary">
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/engine">Engine Overview</a></li>
            <li><a href="/case-studies">Case Studies</a></li>
            <li><a href="/about">About</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <small>Axiomatic BI Showcase</small>
      </div>
    </footer>
  </body>
</html>
