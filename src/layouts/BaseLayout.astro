    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      try {
        const savedTheme = localStorage.getItem("theme");
        if (savedTheme === "light" || savedTheme === "dark") {
          document.documentElement.setAttribute("data-theme", savedTheme);
        }
