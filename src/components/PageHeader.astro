---
interface Props {
  eyebrow?: string;
  title: string;
  lede: string;
  updatedAt?: string;
}

const { eyebrow, title, lede, updatedAt } = Astro.props;
---

<header class="page-header">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h1>{title}</h1>
  <p>{lede}</p>
  {updatedAt && <p><small>Updated: {updatedAt}</small></p>}
</header>
