---
interface Props {
  eyebrow?: string;
  title: string;
  lede: string;
  updatedAt?: string;
}

const { eyebrow, title, lede, updatedAt } = Astro.props;
---

<header>
  {eyebrow && <p>{eyebrow}</p>}
  <h1>{title}</h1>
  <p>{lede}</p>
  {updatedAt && <p><small>Updated: {updatedAt}</small></p>}
</header>
