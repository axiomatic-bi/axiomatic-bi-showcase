---
import { withBase } from "../../utils/urls";

interface NavItem {
  href: string;
  label: string;
}

interface CaseStudyEntry {
  href: string;
  label: string;
}

interface Props {
  navItems: NavItem[];
  caseStudyEntries: CaseStudyEntry[];
  routePathname: string;
}

const { navItems, caseStudyEntries, routePathname } = Astro.props;

function normalisePath(path: string): string {
  if (path === "/") return "/";
  return path.endsWith("/") ? path.slice(0, -1) : path;
}

function isActive(href: string): boolean {
  if (href.includes("#")) return false;
  const routePath = normalisePath(href.split("#")[0] ?? href);
  const currentPath = normalisePath(routePathname);
  if (routePath === "/") return routePathname === "/";
  return currentPath === routePath || currentPath.startsWith(`${routePath}/`);
}
---

<nav aria-label="Primary">
  <ul id="primary-navigation">
    {
      navItems.map((item) => (
        item.href === "/case-studies" ? (
          <li class="nav-item-dropdown">
            <a class="nav-link" href={withBase(item.href)} aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
            </a>
            {caseStudyEntries.length > 0 && (
              <ul class="nav-dropdown" aria-label="Case study pages">
                {caseStudyEntries.map((entry) => (
                  <li>
                    <a class="nav-dropdown-link" href={withBase(entry.href)}>
                      {entry.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ) : (
          <li>
            <a class="nav-link" href={withBase(item.href)} aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          </li>
        )
      ))
    }
  </ul>
</nav>
