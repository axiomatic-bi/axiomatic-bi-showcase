---
interface EvidenceItem {
  type?: "code" | "sql" | "test" | "diagram" | "video";
  label: string;
  path: string;
  note?: string;
}

interface Props {
  title?: string;
  items: EvidenceItem[];
}

const { title = "Evidence", items } = Astro.props;

function toAdrHref(path: string): string | null {
  const match = path.match(/^src\/content\/adr\/(.+)\.md$/);
  if (!match) {
    return null;
  }
  return `/adr/${match[1]}`;
}

function toExternalHref(path: string): string | null {
  return /^https?:\/\//.test(path) ? path : null;
}
---

<aside aria-label={title}>
  <h3>{title}</h3>
  <ul>
    {
      items.map((item) => (
        <li>
          <strong>{item.label}</strong>{" "}
          {item.type && <span>({item.type}) </span>}
          <code>{item.path}</code>{" "}
          {toAdrHref(item.path) && (
            <>
              - <a href={toAdrHref(item.path) ?? "#"}>Open ADR</a>
            </>
          )}
          {toExternalHref(item.path) && (
            <>
              - <a href={toExternalHref(item.path) ?? "#"} target="_blank" rel="noreferrer">Open source</a>
            </>
          )}
          {item.note && <> - {item.note}</>}
        </li>
      ))
    }
  </ul>
</aside>
