---
import { withBase } from "../../utils/urls";

interface EvidenceItem {
  type?: "code" | "sql" | "test" | "diagram" | "video";
  label: string;
  path: string;
  note?: string;
  href?: string;
}

interface Props {
  title?: string;
  items: EvidenceItem[];
}

const { title = "Evidence", items } = Astro.props;

function toAdrHref(path: string): string | null {
  const match = path.match(/^src\/content\/adr\/(.+)\.md$/);
  if (!match) {
    return null;
  }
  return withBase(`/adr/${match[1]}`);
}

function toExternalHref(path: string): string | null {
  return /^https?:\/\//.test(path) ? path : null;
}

function getDisplayHref(item: EvidenceItem): string | null {
  return item.href ?? toAdrHref(item.path) ?? toExternalHref(item.path);
}
---

<aside aria-label={title}>
  <h3>{title}</h3>
  <ul class="evidence-list" role="list">
    {
      items.map((item) => (
        <li class="evidence-item" role="listitem">
          <p class="evidence-label">
            <span class="evidence-label-main">
              <strong>{item.label}</strong> {item.type && <span class="evidence-type">{item.type}</span>}
            </span>
            {item.note && <span class="evidence-status">{item.note}</span>}
          </p>
          <p>
            {getDisplayHref(item) ? (
              <a href={getDisplayHref(item) ?? "#"} target="_blank" rel="noreferrer">
                <code>{item.path}</code>
              </a>
            ) : (
              <code>{item.path}</code>
            )}
          </p>
        </li>
      ))
    }
  </ul>
</aside>

<style>
  .evidence-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .evidence-label-main {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .evidence-status {
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-soft);
    border: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
    border-radius: 999px;
    padding: 0.16rem 0.5rem;
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    white-space: nowrap;
  }
</style>
