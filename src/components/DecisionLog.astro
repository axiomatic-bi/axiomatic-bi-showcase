---
interface Decision {
  id: string;
  status: "accepted" | "proposed" | "superseded";
  summary: string;
  sourcePath: string;
}

interface Props {
  decisions: Decision[];
}

const { decisions } = Astro.props;
const basePrefix = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${basePrefix}${path.replace(/^\/+/, "")}`;

function toAdrHref(path: string): string | null {
  const match = path.match(/^src\/content\/adr\/(.+)\.md$/);
  if (!match) {
    return null;
  }
  return withBase(`/adr/${match[1]}`);
}

function toExternalHref(path: string): string | null {
  return /^https?:\/\//.test(path) ? path : null;
}
---

<div aria-label="Decision log">
  <h3>Decision log</h3>
  <ul>
    {
      decisions.map((decision) => (
        <li>
          <strong>{decision.id}</strong> ({decision.status}) - {decision.summary}{" "}
          <code>{decision.sourcePath}</code>
          {toAdrHref(decision.sourcePath) && (
            <>
              {" "}
              - <a href={toAdrHref(decision.sourcePath) ?? "#"}>Read full ADR</a>
            </>
          )}
          {toExternalHref(decision.sourcePath) && (
            <>
              {" "}
              - <a href={toExternalHref(decision.sourcePath) ?? "#"} target="_blank" rel="noreferrer">Read source ADR</a>
            </>
          )}
        </li>
      ))
    }
  </ul>
</div>
